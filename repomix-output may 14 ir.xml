<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Profile Mobile — Anchored Spread (390px)</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  :root {
    --paper: #f5f1e8;
    --paper-2: #efe9dc;
    --paper-3: #e9e1ce;
    --ink: #1a1916;
    --ink-2: #3a362e;
    --muted: #6b6356;
    --rule: #d8cfbb;
    --rule-strong: #a89b80;
    --accent: #7a2e1f;
    --accent-2: #8a6b1d;
    --accent-3: #2f5d3a;
    --accent-4: #1f3a5f;
  }
  * { box-sizing: border-box; }
  html, body {
    background: #ddd5c0;
    color: var(--ink);
    margin: 0;
    padding: 0;
    font-family: "Source Serif 4", "Iowan Old Style", Georgia, serif;
    -webkit-font-smoothing: antialiased;
  }

  /* Showcase shell — desktop view of the mobile artifact */
  .showcase {
    max-width: 1080px;
    margin: 0 auto;
    padding: 56px 28px 96px;
    display: grid;
    grid-template-columns: 390px 1fr;
    gap: 56px;
    align-items: start;
  }
  @media (max-width: 880px) {
    .showcase { grid-template-columns: 1fr; gap: 32px; }
  }
  .show-head {
    grid-column: 1 / -1;
    border-top: 3px solid var(--ink);
    border-bottom: 1px solid var(--rule-strong);
    padding: 14px 0 10px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-2);
  }
  .show-title {
    grid-column: 1 / -1;
    margin: 24px 0 4px;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .show-deck {
    grid-column: 1 / -1;
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.55;
    margin: 0 0 14px;
    max-width: 720px;
  }

  /* Phone frame */
  .phone {
    width: 390px;
    background: var(--paper);
    border: 1px solid var(--rule-strong);
    box-shadow: 0 1px 0 rgba(0,0,0,0.04), 0 28px 48px -32px rgba(40,30,10,0.35);
    overflow: hidden;
    border-radius: 36px;
    position: relative;
  }
  .phone .notch {
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 110px; height: 22px;
    background: var(--ink);
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
    z-index: 5;
  }
  .status {
    display: flex;
    justify-content: space-between;
    padding: 10px 22px 6px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11.5px;
    color: var(--ink-2);
    font-weight: 600;
  }
  .status .right { display: flex; gap: 6px; align-items: center; }

  /* Top bar */
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid var(--rule);
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11.5px;
    color: var(--ink-2);
  }
  .brand {
    font-family: "Source Serif 4", Georgia, serif;
    font-weight: 700;
    font-size: 14px;
    color: var(--ink);
    letter-spacing: -0.005em;
  }
  .brand .beta {
    margin-left: 6px;
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 9.5px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    font-weight: 500;
  }
  .menu {
    width: 22px; height: 14px;
    display: inline-flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .menu span {
    display: block;
    height: 1.5px;
    background: var(--ink-2);
  }

  /* Section eyebrow / header tab strip */
  .seg {
    display: flex;
    overflow-x: auto;
    border-bottom: 1px solid var(--rule);
    padding: 0 12px;
    gap: 14px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    scrollbar-width: none;
  }
  .seg::-webkit-scrollbar { display: none; }
  .seg a {
    flex: 0 0 auto;
    padding: 12px 4px;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }
  .seg a.active {
    color: var(--ink);
    border-bottom-color: var(--ink);
    font-weight: 700;
  }

  .content { padding: 18px 18px 28px; }

  .eyebrow {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 700;
    margin: 0 0 10px;
  }
  .eyebrow .sep { margin: 0 6px; color: var(--rule-strong); }

  h1.title {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 26px;
    line-height: 1.12;
    font-weight: 700;
    letter-spacing: -0.012em;
    text-wrap: balance;
    margin: 0 0 12px;
  }
  h1.title em {
    font-style: italic;
    color: var(--ink-2);
    font-weight: 600;
  }
  .summary {
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 18px;
    text-wrap: pretty;
  }

  /* Chips — wrap cleanly */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 0 18px;
  }
  .chip {
    flex: 0 0 auto;
    max-width: 100%;
    display: inline-flex;
    flex-direction: column;
    padding: 7px 10px 8px;
    background: var(--paper-2);
    border: 1px solid var(--rule-strong);
    border-radius: 2px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    line-height: 1.25;
  }
  .chip .k {
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-size: 9.5px;
    color: var(--muted);
    font-weight: 700;
  }
  .chip .v {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 13px;
    color: var(--ink);
    font-weight: 600;
    margin-top: 1px;
  }
  .chip.high .v { color: var(--accent); }
  .chip.stable .v { color: var(--accent-3); }

  /* Anchored spread chart — mobile */
  .chart {
    border-top: 2px solid var(--ink);
    border-bottom: 1px solid var(--rule-strong);
    background: #faf6ea;
    margin: 0 -18px 16px;
  }
  .chart-head {
    padding: 12px 18px 8px;
    border-bottom: 1px solid var(--rule);
  }
  .chart-head .t {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.005em;
  }
  .chart-head .scale {
    margin-top: 6px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 9.5px;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .chart-head .scale .c {
    color: var(--ink);
    font-weight: 700;
  }

  .row {
    border-bottom: 1px solid var(--rule);
    padding: 11px 18px 12px;
  }
  .row:last-of-type { border-bottom: 0; }
  .row .nm {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--ink);
  }
  .row .anchor {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 10px;
    color: var(--muted);
    margin-top: 1px;
    letter-spacing: 0.02em;
  }
  .bar {
    position: relative;
    height: 16px;
    margin: 8px 0 6px;
  }
  .bar .axis {
    position: absolute;
    top: -2px; bottom: -2px;
    left: 50%;
    width: 1px;
    background: var(--ink);
  }
  .bar .grid {
    position: absolute;
    top: 0; bottom: 0;
    width: 1px;
    background: var(--rule);
  }
  .bar .fill {
    position: absolute;
    top: 0; bottom: 0;
    background: var(--accent);
    opacity: 0.85;
    border-radius: 1px;
  }
  .row.stable .bar .fill { background: var(--accent-3); opacity: 0.85; }
  .meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.02em;
    color: var(--muted);
  }
  .meta .delta {
    color: var(--accent);
    font-weight: 600;
    font-size: 11px;
  }
  .row.stable .meta .delta { color: var(--accent-3); }

  .chart-foot {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    padding: 10px 18px;
    background: var(--paper-2);
    border-top: 1px solid var(--rule-strong);
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .chart-foot .sw {
    display: inline-block;
    width: 12px; height: 5px;
    margin-right: 5px;
    vertical-align: 1px;
    border-radius: 1px;
  }
  .chart-foot .sw.move { background: var(--accent); }
  .chart-foot .sw.stable { background: var(--accent-3); }

  /* CTA stack */
  .ctas {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0 0 18px;
  }
  .cta {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 13px;
    padding: 11px 14px;
    border-radius: 2px;
    border: 1px solid var(--rule-strong);
    background: var(--paper-2);
    color: var(--ink);
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .cta .arr {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    color: var(--muted);
    font-size: 12px;
  }
  .cta.primary {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
    font-weight: 600;
  }
  .cta.primary .arr { color: var(--paper-3); }

  /* Layer relationship strip — below chart */
  .layer {
    margin: 4px 0 14px;
