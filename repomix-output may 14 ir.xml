  }
  .layer a {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 11px;
    color: var(--accent-4);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-4);
    padding-bottom: 1px;
  }

  /* Collapsible appendix / evidence */
  details.appx {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 0;
    margin: 4px 0 14px;
  }
  details.appx summary {
    list-style: none;
    cursor: pointer;
    padding: 12px 2px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--ink-2);
    font-weight: 600;
  }
  details.appx summary::-webkit-details-marker { display: none; }
  details.appx summary .lbl-l {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 10.5px;
    color: var(--muted);
  }
  details.appx summary .chev {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    color: var(--muted);
    font-size: 12px;
    transition: transform 0.15s ease;
  }
  details.appx[open] summary .chev { transform: rotate(90deg); }
  details.appx .appx-body {
    padding: 0 2px 14px;
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--ink-2);
  }
  details.appx + details.appx { border-top: 0; margin-top: -14px; }
  details.appx ul { margin: 0; padding-left: 16px; }
  details.appx li { margin-bottom: 5px; }

  /* fold marker on phone */
  .fold {
    position: relative;
    margin: 0 -18px;
    border-top: 1px dashed var(--rule-strong);
  }
  .fold span {
    position: absolute;
    top: -8px;
