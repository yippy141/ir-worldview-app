<file path="app/globals.css">
:root {
  --bg: #f7f2ec;
  --panel: #fffdf9;
  --panel-2: #f2ece4;
  --text: #1b1716;
  --muted: #6f6762;
  --accent: #6b1f1a;
  --accent-light: #8b2a24;
  --border: #ddd3ca;
  --border-soft: color-mix(in srgb, var(--border) 72%, white 28%);
  --line: color-mix(in srgb, var(--border) 84%, white 16%);
  --shadow: 0 10px 24px rgba(36, 24, 19, 0.04);
  color-scheme: light;

  /* Tradition-specific accent colors — used for chips, rules, and subtle callouts */
  --t-realist: #6b1f1a;        /* oxblood — matches site accent */
  --t-institutionalist: #2d4a6e; /* slate blue */
  --t-constructivist: #1e5f5c;   /* deep teal */
  --t-cpe: #7a4e28;              /* bronze/umber */
}

* {
  box-sizing: border-box;
}

html,
body {
  padding: 0;
  margin: 0;
  font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
  background: var(--bg);
  color: var(--text);
  -webkit-font-smoothing: antialiased;
}

h1,
h2,
h3 {
  font-family: Georgia, "Times New Roman", serif;
}

a {
  color: var(--accent);
  text-decoration: none;
}

a:hover {
  text-decoration: underline;
}

button {
  font: inherit;
}

/* ── Layout ─────────────────────────────────────────────────────────────────── */

.site-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.site-main {
  flex: 1;
}

.site-header {
  border-bottom: 1px solid var(--line);
  background: color-mix(in srgb, var(--bg) 89%, white 11%);
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 1px 0 rgba(27, 23, 22, 0.02);
  backdrop-filter: blur(10px);
}

.site-shell--quiz {
  background: color-mix(in srgb, var(--bg) 95%, white 5%);
}

.site-shell--quiz .wide-container {
  width: min(1120px, calc(100vw - 40px));
}

.quiz-shell-header {
  position: sticky;
  top: 0;
  z-index: 12;
  border-bottom: 1px solid var(--line);
  background: color-mix(in srgb, var(--panel) 90%, var(--bg) 10%);
  backdrop-filter: blur(10px);
}

.quiz-shell-inner {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
  align-items: center;
  gap: 14px 22px;
  padding: 12px 0 10px;
}

.quiz-shell-brand-link {
  justify-self: start;
  color: inherit;
  text-decoration: none;
  min-width: 0;
}

.quiz-shell-brand-link:hover {
  text-decoration: none;
}

.quiz-shell-brand {
  display: inline-block;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: -0.01em;
}

.quiz-shell-heading {
  min-width: 0;
  text-align: center;
}

.quiz-shell-context {
  min-width: 0;
}

.quiz-shell-label {
  margin: 0;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.11em;
  text-transform: uppercase;
  color: var(--accent-light);
}

.quiz-shell-title {
  margin: 3px 0 0;
  font-size: 1.12rem;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.01em;
  color: var(--text);
}

.quiz-shell-actions {
  justify-self: end;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12px;
  flex-wrap: wrap;
}

.quiz-shell-steps {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.quiz-shell-step {
  display: inline-flex;
  align-items: center;
  padding: 4px 9px;
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--muted);
  background: color-mix(in srgb, var(--panel) 84%, white 16%);
}

.quiz-shell-step--active {
  border-color: color-mix(in srgb, var(--accent) 38%, var(--border) 62%);
  color: var(--accent);
  background: color-mix(in srgb, var(--panel-2) 82%, white 18%);
}

.quiz-shell-exit {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  padding: 0 12px;
  border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border) 70%);
  border-radius: 999px;
  color: var(--accent);
  font-size: 0.84rem;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
}

.quiz-shell-exit:hover {
  text-decoration: none;
  background: color-mix(in srgb, var(--panel) 82%, white 18%);
  border-color: var(--accent);
}

.quiz-shell-brand-link:focus-visible,
.quiz-shell-exit:focus-visible {
  outline: 2px solid color-mix(in srgb, var(--accent) 70%, white 30%);
  outline-offset: 4px;
  border-radius: 999px;
}

.quiz-shell-main {
  padding-top: 30px;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 0 14px;
  gap: 36px;
}

.site-brand-link {
  display: block;
  text-decoration: none;
  color: inherit;
  min-width: fit-content;
}

.header-nav {
  flex: 1;
}

.header-nav-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px 22px;
  flex-wrap: wrap;
}

.nav-link {
  position: relative;
  font-size: 0.88rem;
  color: color-mix(in srgb, var(--muted) 88%, var(--text) 12%);
  text-decoration: none;
  border: none;
  border-radius: 0;
  padding: 6px 0;
  box-shadow: inset 0 -1px 0 transparent;
  transition: color 0.15s ease, box-shadow 0.15s ease;
}

.nav-link:hover {
  color: var(--text);
  text-decoration: none;
  box-shadow: inset 0 -1px 0 color-mix(in srgb, var(--border) 54%, var(--accent) 46%);
}

.nav-link--active {
  color: var(--text);
  box-shadow: inset 0 -1px 0 color-mix(in srgb, var(--border) 48%, var(--accent) 52%);
}

.site-brand-link:focus-visible,
.nav-link:focus-visible,
.nav-disclosure-summary:focus-visible,
.nav-disclosure-link:focus-visible,
.nav-profile-link:focus-visible,
.mobile-nav-summary:focus-visible,
.mobile-nav-link:focus-visible,
.mobile-nav-list-link:focus-visible {
  outline: 2px solid color-mix(in srgb, var(--accent) 70%, white 30%);
  outline-offset: 4px;
  border-radius: 4px;
}

.nav-disclosure {
  position: relative;
}

.nav-disclosure-summary {
  list-style: none;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 0;
  border: none;
  border-radius: 0;
  color: color-mix(in srgb, var(--muted) 88%, var(--text) 12%);
  cursor: pointer;
  box-shadow: inset 0 -1px 0 transparent;
  transition: color 0.15s ease, box-shadow 0.15s ease;
}

.nav-disclosure-summary::-webkit-details-marker,
.mobile-nav-summary::-webkit-details-marker {
  display: none;
}

.nav-disclosure-summary::after {
  content: "▾";
  font-size: 0.72rem;
  color: var(--muted);
}

.nav-disclosure-summary--active {
  color: var(--text);
  box-shadow: inset 0 -1px 0 color-mix(in srgb, var(--border) 48%, var(--accent) 52%);
}

.nav-disclosure:hover .nav-disclosure-summary,
.nav-disclosure[open] .nav-disclosure-summary {
  color: var(--text);
  box-shadow: inset 0 -1px 0 color-mix(in srgb, var(--border) 54%, var(--accent) 46%);
}

.nav-disclosure-menu {
  position: absolute;
  right: auto;
  left: 0;
  top: calc(100% + 12px);
  min-width: 268px;
  max-width: 320px;
  padding: 10px;
  border: 1px solid var(--border-soft);
  border-radius: 10px;
  background: color-mix(in srgb, var(--panel) 92%, white 8%);
  box-shadow: 0 18px 34px rgba(35, 24, 19, 0.08);
  display: none;
  flex-direction: column;
  gap: 6px;
}

.nav-disclosure[open] .nav-disclosure-menu {
  display: flex;
}

.nav-disclosure--end .nav-disclosure-menu {
  left: auto;
  right: 0;
}

.nav-disclosure-menu--compact {
  min-width: 220px;
  padding: 8px;
}

.nav-profile-link {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--accent);
  text-decoration: none;
  padding: 8px 13px;
  border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border) 70%);
  border-radius: 999px;
  transition: background 0.15s ease, border-color 0.15s ease;
}

.nav-profile-link:hover {
  background: color-mix(in srgb, var(--panel) 76%, white 24%);
  border-color: var(--accent);
  text-decoration: none;
}

.nav-disclosure-link {
  display: block;
  padding: 10px 11px;
  border-radius: 7px;
  color: var(--text);
  text-decoration: none;
}

.nav-disclosure-link:hover {
  text-decoration: none;
  background: color-mix(in srgb, var(--panel-2) 72%, white 28%);
}

.nav-disclosure-link--compact {
  padding: 9px 11px;
}

.nav-disclosure-link-title {
  display: block;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text);
  line-height: 1.4;
}

.nav-disclosure-link-text {
  display: block;
  margin-top: 3px;
  font-size: 0.76rem;
  line-height: 1.5;
  color: var(--muted);
}

.mobile-nav {
  display: none;
}

.mobile-nav-summary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 78px;
  padding: 10px 14px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: color-mix(in srgb, var(--panel) 78%, white 22%);
  color: var(--text);
  cursor: pointer;
}

.mobile-nav-sheet {
  margin-top: 14px;
  padding: 18px;
  border: 1px solid var(--border-soft);
  border-radius: 10px;
  background: color-mix(in srgb, var(--panel) 90%, white 10%);
}

.mobile-nav-group + .mobile-nav-group {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid var(--line);
}

.mobile-nav-sheet--compact {
  padding: 18px 18px 8px;
}

.mobile-nav-label {
  margin: 0 0 10px;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--accent);
}

.mobile-nav-links {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.mobile-nav-group-text {
  margin: 0 0 10px;
  font-size: 0.82rem;
  line-height: 1.55;
  color: var(--muted);
}

.mobile-nav-list {
  border-top: 1px solid var(--line);
}

.mobile-nav-list-link {
  display: block;
  padding: 11px 0;
  border-bottom: 1px solid var(--line);
  color: var(--text);
  font-size: 0.92rem;
  font-weight: 600;
  text-decoration: none;
}

.mobile-nav-list-link:hover {
  color: var(--accent);
  text-decoration: none;
}

.mobile-nav-list-link--active {
  color: var(--accent);
}

.mobile-nav-link {
  display: block;
  padding: 10px 12px;
  border: 1px solid var(--border-soft);
  border-radius: 8px;
  color: var(--text);
  background: color-mix(in srgb, var(--panel) 78%, white 22%);
  text-decoration: none;
}

.mobile-nav-link:hover {
  text-decoration: none;
  border-color: color-mix(in srgb, var(--border) 56%, var(--accent) 44%);
}

.mobile-nav-link--primary {
  border-color: color-mix(in srgb, var(--border) 56%, var(--accent) 44%);
  background: color-mix(in srgb, var(--panel) 72%, white 28%);
}

.mobile-nav-link-title {
  display: block;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text);
  line-height: 1.35;
}

.mobile-nav-link-text {
  display: block;
  margin-top: 4px;
  font-size: 0.8rem;
  line-height: 1.5;
  color: var(--muted);
}

/* ── Footer ──────────────────────────────────────────────────────────────────── */

.site-footer {
  border-top: 1px solid var(--line);
  background: color-mix(in srgb, var(--panel-2) 78%, white 22%);
  padding: 28px 0 30px;
  margin-top: auto;
}

.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  flex-wrap: wrap;
}

.footer-brand {
  font-size: 0.82rem;
  color: var(--muted);
  line-height: 1.5;
}

.footer-sep {
  margin: 0 6px;
  color: var(--border);
}

.footer-links {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

.footer-link {
  font-size: 0.82rem;
  color: var(--muted);
  text-decoration: none;
}

.footer-link:hover {
  color: var(--text);
  text-decoration: none;
}

/* ── Tradition accent chips ──────────────────────────────────────────────────── */

.tradition-chip {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 3px;
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: #ffffff;
  margin-bottom: 4px;
}

.tradition--realist        { background: var(--t-realist); }
.tradition--institutionalist { background: var(--t-institutionalist); }
.tradition--constructivist { background: var(--t-constructivist); }
.tradition--cpe            { background: var(--t-cpe); }

/* ── Thinker entries (Explore detail pages) ──────────────────────────────────── */

.thinker-entry {
  padding: 16px 0;
  border-bottom: 1px solid var(--border);
}

.thinker-entry:last-child {
  border-bottom: none;
}

.container {
  width: min(980px, calc(100vw - 40px));
  margin: 0 auto;
}

.wide-container {
  width: min(1400px, calc(100vw - 40px));
  margin: 0 auto;
}

.result-article {
  max-width: 1140px;
  width: 100%;
}

.page-space {
  padding: 52px 0 112px;
}

/* ── Brand ──────────────────────────────────────────────────────────────────── */

.brand {
  margin: 0;
  font-family: Georgia, "Times New Roman", serif;
  font-weight: 700;
  font-size: 1.22rem;
  letter-spacing: -0.02em;
}

.brand-subtitle {
  margin: 5px 0 0;
  color: var(--muted);
  font-size: 0.8rem;
  line-height: 1.45;
  letter-spacing: 0.01em;
  max-width: 40ch;
}

/* ── Panels (for form UI and callouts) ──────────────────────────────────────── */

.panel {
  background: color-mix(in srgb, var(--panel) 88%, white 12%);
  border: 1px solid var(--border-soft);
  border-radius: 10px;
  padding: 40px;
  box-shadow: 0 8px 22px rgba(36, 24, 19, 0.035);
}

.panel-flush {
  background: color-mix(in srgb, var(--panel-2) 80%, white 20%);
  border: 1px solid var(--border-soft);
  border-radius: 7px;
  padding: 20px 24px;
}

/* Smaller, lighter surface for inline callouts */
.callout {
  background: color-mix(in srgb, var(--panel-2) 76%, white 24%);
  border: 1px solid var(--border-soft);
  border-left: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border) 70%);
  border-radius: 9px;
  padding: 18px 22px 18px 20px;
}

/* ── Stack utilities ─────────────────────────────────────────────────────────── */

.stack-xs > * + * { margin-top: 8px; }
.stack-sm > * + * { margin-top: 12px; }
.stack-md > * + * { margin-top: 20px; }
.stack-lg > * + * { margin-top: 32px; }
.stack-xl > * + * { margin-top: 44px; }

/* ── Flex utilities ──────────────────────────────────────────────────────────── */

.row { display: flex; }
.wrap { flex-wrap: wrap; }
.space-between { justify-content: space-between; }
.center { align-items: center; }
.gap-sm { gap: 12px; }
.gap-md { gap: 20px; }

/* ── Typography ──────────────────────────────────────────────────────────────── */

.eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent-light);
  font-size: 0.7rem;
  font-weight: 600;
  margin: 0;
}

.section-kicker {
  margin: 0;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--accent);
}

h1, h2, h3, p { margin: 0; }

h1 {
  font-size: clamp(1.75rem, 3vw, 2.4rem);
  line-height: 1.15;
  letter-spacing: -0.02em;
}

h2 {
  font-size: clamp(1.1rem, 2vw, 1.4rem);
  line-height: 1.3;
  letter-spacing: -0.01em;
}

h3 {
  font-size: 1rem;
  font-family: Georgia, "Times New Roman", serif;
}

.muted { color: var(--muted); }

.mode-pill {
  display: inline-flex;
  align-items: center;
  padding: 7px 12px;
  border: 1px solid var(--border);
  background: var(--panel-2);
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--accent);
}

.divider {
  border: none;
  border-top: 1px solid var(--line);
  margin: 0;
}

/* ── CTAs (link-style buttons) ───────────────────────────────────────────────── */

.cta-primary {
  display: inline-block;
  background: var(--accent);
  color: #ffffff;
  border: 1px solid var(--accent);
  border-radius: 999px;
  padding: 11px 22px;
  font-size: 0.9rem;
  font-weight: 600;
  text-decoration: none;
  transition: background 0.15s ease;
}

.cta-primary:hover {
  background: var(--accent-light);
  border-color: var(--accent-light);
  text-decoration: none;
}

.cta-secondary {
  display: inline-block;
  background: var(--panel);
  color: var(--text);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 11px 22px;
  font-size: 0.9rem;
  text-decoration: none;
  transition: border-color 0.15s ease;
}

.cta-secondary:hover {
  border-color: var(--accent);
  text-decoration: none;
}

/* ── Buttons ─────────────────────────────────────────────────────────────────── */

.answer-button,
.primary-button,
.secondary-button,
.option-card {
  border-radius: 5px;
  border: 1px solid var(--border);
  color: var(--text);
  cursor: pointer;
  transition: border-color 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
}

.answer-button,
.primary-button,
.secondary-button {
  padding: 10px 18px;
}

.answer-button,
.secondary-button,
.option-card {
  background: var(--panel);
}

.primary-button {
  background: var(--accent);
  color: #ffffff;
  font-weight: 600;
  border-color: var(--accent);
}

.answer-button:hover,
.secondary-button:hover,
.option-card:hover {
  border-color: var(--accent);
  box-shadow: 0 0 0 1px var(--accent);
}

.primary-button:hover {
  background: var(--accent-light);
  border-color: var(--accent-light);
}

.answer-button.selected,
.option-card.selected {
  border-color: var(--accent);
  background: rgba(107, 31, 26, 0.06);
  box-shadow: 0 0 0 1px var(--accent);
}

.secondary-button:disabled,
.primary-button:disabled {
  opacity: 0.35;
  cursor: not-allowed;
  box-shadow: none;
}

.option-card {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  align-items: flex-start;
  gap: 16px;
  width: 100%;
  text-align: left;
  padding: 18px 20px;
}

.option-card-content {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.option-card-title {
  display: block;
  font-weight: 600;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1rem;
  line-height: 1.35;
  color: var(--text);
}

.option-card-text {
  display: block;
  color: var(--muted);
  font-size: 0.92rem;
  line-height: 1.65;
}

.option-card-meta {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--accent);
}

.option-card-meta--secondary {
  color: var(--muted);
}

.option-badge {
  width: 30px;
  height: 30px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: var(--panel-2);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.78rem;
  font-weight: 600;
  flex-shrink: 0;
  color: var(--muted);
  transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  margin-top: 2px;
}

.option-card.selected .option-badge {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
}

/* ── Progress bars ───────────────────────────────────────────────────────────── */

.progress-meta {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  font-size: 0.875rem;
  color: var(--muted);
}

.progress-bar {
  width: 100%;
  height: 6px;
  background: var(--panel-2);
  border: 1px solid var(--border);
  border-radius: 999px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 999px;
  transition: width 0.3s ease;
}

/* ── Likert ──────────────────────────────────────────────────────────────────── */

.likert-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8px;
}

.likert-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  color: var(--muted);
  padding: 0 2px;
}

/* ── Landing page ────────────────────────────────────────────────────────────── */

.landing-page {
  width: min(1180px, calc(100vw - 40px));
  margin: 0 auto;
}

.landing-hero {
  padding: 60px 0 44px;
  border-bottom: 1px solid var(--line);
}

.landing-hero-compact {
  max-width: 640px;
}

.landing-hero-ctas {
  display: flex;
  flex-direction: column;
  gap: 10px;
  align-items: flex-start;
}

/* ── Lobby menu ──────────────────────────────────────────────────────────────── */

.landing-lobby {
  padding: 0;
}

.landing-lobby-list {
  border-bottom: 1px solid var(--line);
}

.lobby-menu-item {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 24px;
  align-items: center;
  padding: 22px 0;
  border-top: 1px solid var(--line);
  color: var(--text);
  text-decoration: none;
  transition: background 0.12s ease;
}

@media (max-width: 640px) {
  .lobby-menu-item {
    grid-template-columns: 1fr;
    gap: 10px;
  }
}

.lobby-menu-item:hover {
  text-decoration: none;
}

.lobby-menu-item:hover .lobby-menu-label {
  color: var(--accent);
}

.lobby-menu-item--primary .lobby-menu-label {
  color: var(--accent);
}

.lobby-menu-copy {
  min-width: 0;
}

.lobby-menu-label {
  font-size: 1.05rem;
  font-weight: 700;
  font-family: Georgia, "Times New Roman", serif;
  line-height: 1.3;
  transition: color 0.12s ease;
  margin: 0 0 5px;
}

.lobby-menu-desc {
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--muted);
  max-width: 62ch;
  margin: 0;
}

.lobby-menu-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
  flex-shrink: 0;
  min-width: 100px;
  text-align: right;
}

.lobby-menu-meta {
  font-size: 0.76rem;
  color: var(--muted);
  line-height: 1.5;
}

.lobby-menu-arrow {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--accent);
}

/* Keep old landing grid styles for backward compat on other pages */
.landing-hero-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
  align-items: start;
}

@media (min-width: 820px) {
  .landing-hero-grid {
    grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.78fr);
    gap: 72px;
  }
}

.landing-side-stack {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.landing-side-panel {
  background: color-mix(in srgb, var(--panel) 84%, white 16%);
  border-radius: 8px;
  padding: 16px 20px;
}

.landing-display {
  font-size: clamp(1.65rem, 3.2vw, 2.6rem);
  letter-spacing: -0.03em;
  line-height: 1.12;
  max-width: 22ch;
}

.landing-lead {
  max-width: 50ch;
  font-size: 1rem;
  line-height: 1.74;
  color: var(--muted);
}

.landing-note {
  max-width: 56ch;
  font-size: 0.88rem;
  line-height: 1.68;
  color: var(--muted);
}

.landing-action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
}

.landing-primary-cta {
  align-self: flex-start;
}

.landing-draft-note {
  margin: 0;
  font-size: 0.82rem;
  line-height: 1.55;
  color: var(--muted);
}

.landing-quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.lobby-path-list {
  border-top: 1px solid var(--line);
}

.lobby-path-link {
  display: block;
  padding: 16px 0;
  border-bottom: 1px solid var(--line);
  color: var(--text);
  text-decoration: none;
}

.lobby-path-link:hover {
  text-decoration: none;
}

.landing-quick-card {
  display: block;
  height: 100%;
  color: var(--text);
  text-decoration: none;
}

.landing-quick-card:hover {
  text-decoration: none;
}

.landing-quick-kicker {
  margin: 0;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent-light);
}

.landing-quick-title {
  margin: 0;
  font-size: 1rem;
  font-weight: 700;
  font-family: Georgia, "Times New Roman", serif;
  line-height: 1.35;
  color: var(--text);
}

.landing-quick-text {
  margin: 0;
  font-size: 0.88rem;
  line-height: 1.62;
  color: var(--muted);
}

.landing-quick-meta {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--accent);
}

.landing-route-list {
  border-top: 1px solid var(--line);
}

.landing-route-item {
  padding: 14px 0;
  border-bottom: 1px solid var(--line);
}

.landing-route-title {
  font-weight: 600;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 0.96rem;
}

.landing-route-text {
  margin-top: 4px;
  color: var(--muted);
  font-size: 0.88rem;
  line-height: 1.6;
}

.menu-card {
  display: block;
  background: color-mix(in srgb, var(--panel) 88%, white 12%);
  border: 1px solid var(--border-soft);
  border-radius: 10px;
  padding: 22px 24px;
  text-decoration: none;
  color: var(--text);
  transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
}

.menu-card:hover {
  border-color: color-mix(in srgb, var(--border) 60%, var(--accent) 40%);
  background: color-mix(in srgb, var(--panel) 78%, white 22%);
  transform: translateY(-1px);
  text-decoration: none;
}

.menu-card-title {
  font-weight: 600;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1rem;
  margin: 0 0 4px;
  color: var(--text);
}

.menu-card-desc {
  font-size: 0.85rem;
  color: var(--muted);
  line-height: 1.6;
  margin: 0;
}

.landing-section {
  padding: 60px 0;
  border-top: 1px solid var(--line);
}

.landing-family-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 34px;
  align-items: start;
}

@media (min-width: 980px) {
  .landing-family-grid {
    grid-template-columns: minmax(320px, 0.88fr) minmax(0, 1.12fr);
    gap: 56px;
  }
}

.landing-feature-card {
  background: color-mix(in srgb, var(--panel) 92%, white 8%);
  border: 1px solid var(--border-soft);
  border-radius: 12px;
  padding: 32px 34px;
  box-shadow: 0 12px 30px rgba(36, 24, 19, 0.04);
}

.landing-feature-text {
  font-size: 0.98rem;
  line-height: 1.75;
  color: var(--muted);
}

.signal-list {
  display: grid;
  gap: 14px;
}

.signal-list--three {
  grid-template-columns: 1fr;
}

@media (min-width: 900px) {
  .signal-list--three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

.signal-list-item {
  padding-top: 14px;
  border-top: 1px solid var(--line);
  color: var(--muted);
  font-size: 0.9rem;
  line-height: 1.65;
}

.signal-list-item strong {
  display: block;
  margin-bottom: 6px;
  color: var(--text);
  font-family: Georgia, "Times New Roman", serif;
  font-size: 0.98rem;
  font-weight: 600;
}

.landing-family-rail {
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.landing-family-heading {
  max-width: 18ch;
}

.landing-rail-list {
  border-top: 1px solid var(--line);
}

.landing-rail-link {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 20px;
  align-items: start;
  padding: 18px 0;
  border-bottom: 1px solid var(--line);
  color: var(--text);
  text-decoration: none;
}

.landing-rail-link:hover {
  text-decoration: none;
}

.landing-rail-copy {
  min-width: 0;
}

.landing-rail-title {
  font-size: 1rem;
  font-weight: 600;
  font-family: Georgia, "Times New Roman", serif;
}

.landing-rail-text {
  margin-top: 4px;
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--muted);
}

.landing-rail-meta {
  display: flex;
  flex-direction: column;
  gap: 10px;
  align-items: flex-end;
  font-size: 0.78rem;
  color: var(--muted);
  text-align: right;
}

.landing-rail-arrow {
  color: var(--accent);
  font-weight: 600;
}

.landing-section--closing {
  padding-bottom: 24px;
}

.landing-closing-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}

@media (min-width: 900px) {
  .landing-closing-grid {
    grid-template-columns: minmax(0, 1.2fr) minmax(220px, 0.6fr);
    align-items: start;
  }
}

.landing-closing-text {
  max-width: 58ch;
  color: var(--muted);
  line-height: 1.75;
  font-size: 0.94rem;
}

.landing-closing-links {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.landing-text-link {
  display: block;
  padding: 12px 0;
  border-top: 1px solid var(--line);
  color: var(--text);
  text-decoration: none;
}

.landing-text-link:last-child {
  border-bottom: 1px solid var(--line);
}

.landing-text-link:hover {
  text-decoration: none;
  color: var(--accent);
}

.dimension-list {
  margin-top: 4px;
}

.dimension-row {
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
}

.dimension-row:last-child {
  border-bottom: none;
}

/* ── Atlas layout (two-column for explore slug pages) ───────────────────────── */

.atlas-layout {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 48px;
  align-items: start;
}

.atlas-toc {
  position: sticky;
  top: 80px;
}

.atlas-toc-link {
  display: block;
  padding: 6px 0;
  font-size: 0.82rem;
  color: var(--muted);
  text-decoration: none;
  border-left: 2px solid transparent;
  padding-left: 10px;
  transition: color 0.15s ease, border-color 0.15s ease;
}

.atlas-toc-link:hover {
  color: var(--text);
  border-left-color: var(--accent);
  text-decoration: none;
}

.atlas-body {
  min-width: 0;
}

/* ── Issue comparisons ───────────────────────────────────────────────────────── */

.compare-issue {
  padding: 28px 0;
  border-bottom: 1px solid var(--border);
}

.compare-issue:last-child {
  border-bottom: none;
}

.compare-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-top: 16px;
}

.module-card-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.module-meta-grid {
  display: grid;
  grid-template-columns: minmax(0, 260px) minmax(0, 1fr);
  gap: 18px;
  align-items: start;
}

.module-linkage-panel {
  padding: 24px 26px;
  border: 1px solid var(--border-soft);
  border-radius: 10px;
  background: color-mix(in srgb, var(--panel) 90%, white 10%);
}

.module-linkage-strip {
  display: grid;
  grid-template-columns: minmax(220px, 0.42fr) minmax(0, 1fr);
  gap: 18px;
  align-items: start;
  padding: 18px 20px;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: color-mix(in srgb, var(--panel) 88%, white 12%);
}

.module-linkage-strip-text {
  margin: 0;
  color: var(--text);
  font-size: 0.94rem;
  line-height: 1.68;
}

.module-linkage-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

.module-linkage-card {
  min-width: 0;
  padding: 18px 20px;
  border: 1px solid var(--border-soft);
  border-radius: 9px;
  background: color-mix(in srgb, var(--panel-2) 72%, white 28%);
}

.module-linkage-kicker {
  margin: 0;
  font-size: 0.74rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--accent);
}

.module-linkage-title {
  margin: 0;
  color: var(--text);
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.02rem;
  line-height: 1.3;
}

.module-linkage-text {
  margin: 0;
  color: var(--muted);
  font-size: 0.9rem;
  line-height: 1.62;
}

.module-linkage-list {
  margin: 0;
  color: var(--muted);
  font-size: 0.9rem;
  line-height: 1.62;
}

.module-mode-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.module-secondary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 10px;
}

.module-lane-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.module-lane-grid--compact {
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
}

.module-lane-card {
  background: color-mix(in srgb, var(--panel) 84%, white 16%);
  border: 1px solid var(--border-soft);
  border-radius: 7px;
  padding: 16px 18px;
}

.module-scope-details {
  background: color-mix(in srgb, var(--panel) 94%, white 6%);
}

.module-scope-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20px 24px;
  padding: 18px 0 16px;
}

.module-note-list {
  margin: 0;
  color: var(--muted);
  font-size: 0.9rem;
  line-height: 1.62;
}

.module-coverage-line {
  margin: 0;
  padding: 14px 0 16px;
  border-top: 1px solid var(--border-soft);
  color: var(--muted);
  font-size: 0.82rem;
  line-height: 1.58;
}

.module-case-frame {
  padding-bottom: 8px;
  border-bottom: 1px solid var(--border);
}

.secondary-choice-button {
  border-radius: 5px;
  border: 1px solid var(--border);
  background: var(--panel);
  color: var(--text);
  padding: 12px 14px;
  text-align: left;
  cursor: pointer;
  transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}

.secondary-choice-button:hover {
  border-color: var(--accent);
  box-shadow: 0 0 0 1px var(--accent);
}

.secondary-choice-button.selected {
  border-color: var(--accent);
  background: rgba(107, 31, 26, 0.06);
  box-shadow: 0 0 0 1px var(--accent);
}

.compare-cell {
  background: color-mix(in srgb, var(--panel) 84%, white 16%);
  border: 1px solid var(--border-soft);
  border-radius: 7px;
  padding: 16px;
}

.compare-cell-label {
  font-weight: 600;
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--accent);
  margin-bottom: 8px;
}

/* ── Subtradition entries ────────────────────────────────────────────────────── */

.subtradition-entry {
  padding: 16px 0;
  border-bottom: 1px solid var(--border);
}

.subtradition-entry:last-child {
  border-bottom: none;
}

/* ── Personalization sections (result page) ──────────────────────────────────── */

.issue-tilt-row {
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
}

.issue-tilt-row:last-child {
  border-bottom: none;
}

.flip-note {
  border-left: 3px solid var(--accent-light);
  padding: 12px 16px;
  background: var(--panel-2);
  border-radius: 0 5px 5px 0;
}

/* ── Primary vs runner-up comparison strip ───────────────────────────────────── */

.comparison-strip {
  border: 1px solid var(--border);
  border-radius: 5px;
  overflow: hidden;
}

.comparison-header {
  display: grid;
  grid-template-columns: 1fr 120px 60px 120px;
  gap: 12px;
  padding: 10px 16px;
  background: var(--panel-2);
  border-bottom: 1px solid var(--border);
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
}

.comparison-row {
  display: grid;
  grid-template-columns: 1fr 120px 60px 120px;
  gap: 12px;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  align-items: center;
}

.comparison-row:last-child {
  border-bottom: none;
}

.comparison-label {
  font-size: 0.875rem;
  color: var(--text);
}

.comparison-score-head,
.comparison-score {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text);
  text-align: center;
}

.comparison-family {
  text-align: center;
}

.comparison-expected {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  text-align: center;
}

.comparison-expected--high {
  color: var(--accent);
}

.comparison-expected--low {
  color: var(--muted);
}

.comparison-expected--neutral {
  color: var(--muted);
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
  font-style: italic;
}

@media (max-width: 600px) {
  .comparison-header,
  .comparison-row {
    grid-template-columns: 1fr 60px 80px;
  }

  .comparison-family:last-child {
    display: none;
  }

  .module-card-grid,
  .module-meta-grid,
  .module-lane-grid {
    grid-template-columns: 1fr;
  }
}

/* ── History compare ─────────────────────────────────────────────────────────── */

.compare-section-label {
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--muted);
  margin-bottom: 8px;
}

.history-shift-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 12px;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
}

.history-shift-row:last-child {
  border-bottom: none;
}

.history-shift-value {
  font-size: 0.875rem;
  font-variant-numeric: tabular-nums;
  flex-shrink: 0;
  color: var(--muted);
}

/* ── References page ─────────────────────────────────────────────────────────── */

.ref-toc {
  display: flex;
  flex-wrap: wrap;
  gap: 6px 20px;
  padding: 20px 0;
}

.ref-toc-link {
  font-size: 0.875rem;
  color: var(--accent);
  text-decoration: none;
}

.ref-toc-link:hover {
  text-decoration: underline;
}

.ref-entry {
  padding: 20px 0;
  border-bottom: 1px solid var(--border);
}

.ref-entry:last-child {
  border-bottom: none;
}

.ref-citation {
  font-size: 0.9rem;
  line-height: 1.6;
  margin: 0;
}

/* ── Article pages (explore, method) ─────────────────────────────────────────── */

.article-page {
  max-width: 760px;
}

.article-header {
  position: relative;
  isolation: isolate;
  padding: 60px 0 40px;
}

.lobby-page {
  max-width: 1180px;
}

.lobby-hero {
  position: relative;
  isolation: isolate;
  padding: 68px 0 42px;
  border-bottom: 1px solid var(--line);
}

.lobby-hero--plain {
  padding-bottom: 18px;
  border-bottom: none;
}

.lobby-hero-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
  align-items: start;
}

@media (min-width: 960px) {
  .lobby-hero-grid {
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.82fr);
    gap: 52px;
  }
}

.lobby-lead {
  max-width: 58ch;
  font-size: 1.06rem;
  line-height: 1.82;
  color: var(--muted);
}

.lobby-side-note {
  min-width: 0;
}

.lobby-side-note--offset {
  min-width: 0;
}

.lobby-hero-aside {
  min-width: 0;
}

.lobby-hero-panel {
  min-width: 0;
  padding: 24px 26px;
  border: 1px solid var(--border-soft);
  border-radius: 10px;
  background: color-mix(in srgb, var(--panel) 88%, white 12%);
}

.lobby-journey-panel {
  min-width: 0;
  padding: 28px 28px 24px;
  border: 1px solid color-mix(in srgb, var(--border-soft) 78%, var(--accent) 22%);
  border-radius: 18px;
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--panel) 92%, white 8%), color-mix(in srgb, var(--panel-2) 70%, white 30%));
  box-shadow: 0 16px 32px rgba(36, 24, 19, 0.035);
}

.lobby-step-list {
  display: grid;
  gap: 0;
}

.lobby-step {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 14px;
  align-items: start;
  padding: 16px 0;
  border-top: 1px solid var(--line);
}

.lobby-step:first-child {
  padding-top: 0;
  border-top: none;
}

.lobby-step-number {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
