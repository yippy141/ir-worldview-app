    overflow-wrap: anywhere;
  }

  .profile-hero-head h1 {
    width: min(100%, 16ch);
    max-width: 16ch;
    font-size: clamp(1.55rem, 7vw, 1.95rem);
  }

  .profile-stat-chips {
    display: grid;
    grid-template-columns: 1fr;
  }

  .profile-spread__lane-meta {
    align-items: flex-start;
