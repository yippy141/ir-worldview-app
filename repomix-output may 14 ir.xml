.profile-spread__head {
  display: grid;
  grid-template-columns: 1fr;
  gap: 4px;
  padding: 12px 18px 10px;
  border-bottom: 1px solid var(--line);
}

.profile-spread__title {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 0.96rem;
  font-weight: 700;
  color: var(--text);
}

.profile-spread__scale {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 10px;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--muted);
}

.profile-spread__scale-l { text-align: left; }
.profile-spread__scale-c { text-align: center; color: var(--text); font-weight: 700; }
.profile-spread__scale-r { text-align: right; }

@media (max-width: 480px) {
  .profile-hero--anchored > .profile-hero-head,
  .profile-hero--anchored > .profile-hero-summary,
  .profile-hero--anchored > .profile-stat-chips,
  .profile-hero--anchored > .profile-spread,
  .profile-hero--anchored > .profile-hero-ctas,
  .profile-hero--anchored > .profile-hero-meta,
  .profile-layer-strip {
    width: 350px;
    max-width: 350px;
  }

  .profile-spread__scale {
    grid-template-columns: 1fr;
    font-size: 0.62rem;
    gap: 6px;
  }

  .profile-spread__scale-l,
  .profile-spread__scale-c,
  .profile-spread__scale-r {
    text-align: left;
  }

  .profile-spread__anchor-key {
    margin-left: 0;
  }
}

.profile-spread__row {
  display: grid;
  grid-template-columns: 1fr;
  border-bottom: 1px solid var(--line);
}

.profile-spread__row:last-of-type { border-bottom: 0; }

.profile-spread__label {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 12px 18px 4px;
}

.profile-spread__name {
  font-size: 0.86rem;
  font-weight: 600;
  color: var(--text);
}

.profile-spread__anchor {
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.72rem;
  letter-spacing: 0.02em;
  color: var(--muted);
}

.profile-spread__bar {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 8px 18px 12px;
  min-width: 0;
}

.profile-spread__track {
  position: relative;
  height: 22px;
  border-radius: 1px;
}

.profile-spread__axis {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 1px;
  background: var(--text);
}

.profile-spread__grid {
  position: absolute;
  top: 4px;
  bottom: 4px;
  width: 1px;
  background: var(--line);
}

.profile-spread__fill {
  position: absolute;
  top: 3px;
  bottom: 3px;
  background: var(--accent);
  opacity: 0.9;
  border-radius: 1px;
}

.profile-spread__fill--stable {
  background: transparent;
  border: 1.5px solid var(--t-constructivist);
  opacity: 1;
}

.profile-spread__lane-meta {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 4px 12px;
  min-width: 0;
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.7rem;
  letter-spacing: 0.02em;
  color: var(--muted);
}

.profile-spread__delta {
  color: var(--accent);
  font-weight: 600;
}

.profile-spread__row--stable .profile-spread__delta {
  color: var(--t-constructivist);
}

.profile-spread__foot {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px 18px;
  padding: 10px 18px;
  border-top: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
  background: color-mix(in srgb, var(--panel) 86%, white 14%);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--muted);
}

.profile-spread__sw {
  display: inline-block;
  width: 14px;
  height: 6px;
  margin-right: 6px;
  vertical-align: 1px;
  border-radius: 1px;
}

.profile-spread__sw--move {
  background: var(--accent);
}

.profile-spread__sw--stable {
  background: transparent;
  border: 1.5px solid var(--t-constructivist);
  height: 4px;
}

.profile-spread__anchor-key {
  margin-left: auto;
  text-transform: none;
  letter-spacing: 0.02em;
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-weight: 500;
  color: var(--text);
}

.profile-ai-band {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 14px;
  align-items: baseline;
  padding: 10px 14px;
  border: 1px solid var(--border);
  border-left: 3px solid var(--t-institutionalist);
  background: color-mix(in srgb, var(--panel) 88%, white 12%);
}

.profile-ai-band--pending {
  border-left-color: var(--muted);
  border-left-style: dashed;
}

.profile-ai-band__lbl {
  flex: 0 0 auto;
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--t-institutionalist);
}

.profile-ai-band__body {
  flex: 1 1 240px;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 0.92rem;
  line-height: 1.55;
  color: var(--text);
}

.profile-ai-band__open {
  flex: 0 0 auto;
  margin-left: auto;
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.78rem;
  color: var(--t-institutionalist);
  text-decoration: none;
  border-bottom: 1px solid var(--t-institutionalist);
  padding-bottom: 1px;
}

.profile-hero-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding-top: 16px;
  border-top: 1px solid var(--line);
}

.profile-hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 9px 14px;
  border: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
  border-radius: 2px;
  background: color-mix(in srgb, var(--panel) 80%, white 20%);
  color: var(--text);
  font-size: 0.84rem;
  font-weight: 500;
  letter-spacing: 0.01em;
  text-decoration: none;
  line-height: 1.2;
}

.profile-hero-cta:hover {
  border-color: var(--text);
  text-decoration: none;
}

.profile-hero-cta__title {
  min-width: 0;
}

.profile-hero-cta--primary {
  background: var(--text);
  color: var(--panel);
  border-color: var(--text);
  font-weight: 600;
}

.profile-hero-cta--primary .profile-hero-cta__arr {
  color: color-mix(in srgb, var(--panel) 80%, white 20%);
}

.profile-hero-cta__arr {
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.84rem;
  color: var(--muted);
}

.profile-hero-meta {
  margin: 0;
  padding-top: 4px;
  font-size: 0.78rem;
  line-height: 1.55;
}

.profile-secondary-actions {
  padding-top: 18px;
  border-top: 1px solid var(--line);
}

@media (min-width: 720px) {
  .profile-spread__row {
    grid-template-columns: 280px 1fr;
  }

  .profile-spread__label {
    border-right: 1px solid var(--line);
    padding: 14px 22px;
  }

  .profile-spread__bar {
    padding: 14px 22px 14px;
  }

  .profile-spread__head {
    grid-template-columns: 280px 1fr;
    align-items: end;
    padding: 14px 22px 10px;
  }
}

/* Thin top rule in tradition color — only accent on hero */
.result-hero-rule {
  height: 3px;
  border-radius: 2px;
  margin-bottom: 28px;
  background: var(--accent);
}

.result-hero-rule--realist        { background: var(--t-realist); }
.result-hero-rule--institutionalist { background: var(--t-institutionalist); }
.result-hero-rule--constructivist { background: var(--t-constructivist); }
.result-hero-rule--cpe            { background: var(--t-cpe); }

.result-section {
  padding: 60px 0;
  border-bottom: 1px solid var(--line);
}

.result-section > .stack-xs > h2,
.homepage-band-header h2,
.profile-mosaic-header h2 {
  letter-spacing: -0.02em;
}

.result-section:last-child {
  border-bottom: none;
}

.profile-module-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 18px;
}

.module-relation-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}

.module-relation-card {
  min-width: 0;
  padding: 20px 22px;
  border: 1px solid var(--border-soft);
  border-radius: 10px;
  background: color-mix(in srgb, var(--panel) 90%, white 10%);
}

.module-relation-card--reinforce {
  border-left: 3px solid color-mix(in srgb, var(--t-constructivist) 48%, var(--border) 52%);
}

.module-relation-card--complicate {
  border-left: 3px solid color-mix(in srgb, var(--t-institutionalist) 48%, var(--border) 52%);
}

.module-relation-card--pull {
  border-left: 3px solid color-mix(in srgb, var(--accent) 50%, var(--border) 50%);
}

.module-relation-kicker {
  margin: 0;
  font-size: 0.74rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--accent);
}

.module-relation-list {
  margin: 0;
  color: var(--muted);
  font-size: 0.9rem;
  line-height: 1.64;
}

.module-decisive-list {
  display: grid;
  gap: 18px;
}

.module-decisive-call {
  display: grid;
  grid-template-columns: minmax(120px, 0.24fr) minmax(0, 1fr);
  gap: 22px;
  padding: 20px 0;
  border-top: 1px solid color-mix(in srgb, var(--border) 72%, var(--accent) 28%);
}

.module-decisive-call:last-child {
  border-bottom: 1px solid var(--border-soft);
}

.module-decisive-meta {
  display: grid;
  gap: 8px;
  align-content: start;
  color: var(--muted);
  font-family: var(--sans);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.module-decisive-call h3 {
  margin: 0;
  font-size: 1.08rem;
  line-height: 1.32;
}

.module-decisive-framing {
  margin: 0;
  color: var(--text);
  font-family: Georgia, "Times New Roman", serif;
  font-size: 0.98rem;
  font-weight: 600;
  line-height: 1.42;
}

@media (min-width: 900px) {
  .atlas-page-intro {
    grid-template-columns: minmax(0, 1.18fr) minmax(260px, 0.82fr);
    align-items: end;
  }

  .module-linkage-grid,
  .module-relation-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .ai-bridge-grid,
  .profile-summary-grid,
  .profile-next-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

.profile-module-grid--report {
  gap: 30px 34px;
}

.profile-module-entry {
  min-width: 0;
  padding-top: 18px;
  border-top: 1px solid var(--line);
}

.profile-module-lane {
  padding-top: 12px;
  border-top: 1px solid var(--border);
}

.profile-module-lane:first-child {
  padding-top: 0;
  border-top: none;
}

.profile-module-note {
  margin: 0;
  padding-left: 16px;
  border-left: 2px solid color-mix(in srgb, var(--accent) 16%, var(--border) 84%);
}

.profile-module-note--accent {
  border-left-color: color-mix(in srgb, var(--accent) 42%, var(--border) 58%);
}

.module-lane-summary {
  padding-top: 10px;
  border-top: 1px solid var(--border);
}

.module-lane-summary:first-child {
  padding-top: 0;
  border-top: none;
}

.profile-mini-scale {
  width: 100%;
  height: 5px;
  border-radius: 999px;
  background: var(--panel-2);
  border: 1px solid var(--border);
  overflow: hidden;
}

.profile-mini-scale-fill {
  height: 100%;
  border-radius: 999px;
}

.module-lane-meter {
  padding-top: 4px;
}

/* ── V10.1 shared visual primitives ───────────────────────────────────────── */

.v10-scale-bar,
.v10-segmented-level,
.v10-comparison-row,
.v10-layer-stack {
  --v10-tone: var(--accent);
}

.v10-scale-bar[data-tone="baseline"],
.v10-segmented-level[data-tone="baseline"],
.v10-comparison-row__marker[data-tone="baseline"],
.v10-comparison-row__legend-marker[data-tone="baseline"] {
  --v10-tone: var(--text);
}

.v10-scale-bar[data-tone="security"],
.v10-segmented-level[data-tone="security"],
.v10-comparison-row__marker[data-tone="security"],
.v10-comparison-row__legend-marker[data-tone="security"] {
  --v10-tone: var(--accent);
}

.v10-scale-bar[data-tone="technology"],
.v10-segmented-level[data-tone="technology"],
.v10-comparison-row__marker[data-tone="technology"],
.v10-comparison-row__legend-marker[data-tone="technology"] {
  --v10-tone: var(--t-institutionalist);
}

.v10-scale-bar[data-tone="ai"],
.v10-segmented-level[data-tone="ai"],
.v10-comparison-row__marker[data-tone="ai"],
.v10-comparison-row__legend-marker[data-tone="ai"] {
  --v10-tone: var(--t-constructivist);
}

.v10-scale-bar[data-tone="muted"],
.v10-segmented-level[data-tone="muted"],
.v10-comparison-row__marker[data-tone="muted"],
.v10-comparison-row__legend-marker[data-tone="muted"] {
  --v10-tone: var(--muted);
}

.v10-scale-bar {
  display: grid;
  gap: 8px;
  min-width: 0;
}

.v10-scale-bar__meta,
.v10-scale-bar__poles {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  min-width: 0;
}

.v10-scale-bar__meta--value-only {
  justify-content: flex-end;
}

.v10-scale-bar__label {
  color: var(--text);
  font-size: 0.9rem;
  font-weight: 600;
  line-height: 1.35;
}

.v10-scale-bar__value {
  flex-shrink: 0;
  color: var(--muted);
  font-size: 0.84rem;
  font-variant-numeric: tabular-nums;
  line-height: 1.35;
}

.v10-scale-bar__track {
  width: 100%;
  height: 12px;
  overflow: hidden;
  border: 1px solid var(--border);
  border-radius: 4px;
  background: var(--panel);
}

.v10-scale-bar__fill {
  display: block;
  width: var(--v10-scale-value, 0%);
  min-width: 3px;
  height: 100%;
  border-right: 3px solid currentColor;
  background: currentColor;
  color: var(--v10-tone);
}

.v10-scale-bar__poles {
  color: var(--muted);
  font-size: 0.76rem;
  line-height: 1.4;
}

.v10-scale-bar__poles span:last-child {
  text-align: right;
}

.v10-segmented-level {
  display: grid;
  grid-template-columns: minmax(96px, 1fr) minmax(96px, 128px) auto;
  gap: 10px;
  align-items: center;
  min-width: 0;
  color: var(--v10-tone);
}

.v10-segmented-level--compact {
  grid-template-columns: minmax(86px, 1fr) minmax(78px, 104px) auto;
  gap: 8px;
}

.v10-segmented-level__label {
  min-width: 0;
  color: var(--text);
  font-size: 0.84rem;
  line-height: 1.35;
}

.v10-segmented-level__cells {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 5px;
  min-width: 0;
}

.v10-segmented-level__cell {
  height: 16px;
  border: 1px solid var(--border);
  border-radius: 3px;
  background: var(--panel);
}

.v10-segmented-level--compact .v10-segmented-level__cell {
  height: 13px;
}

.v10-segmented-level__cell--active {
  border-color: currentColor;
  border-width: 2px;
  background: currentColor;
}

.v10-segmented-level__value {
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 600;
  line-height: 1.35;
}

.v10-comparison-row {
  display: grid;
  gap: 10px;
  min-width: 0;
}

.v10-comparison-row__header {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
  align-items: start;
}

.v10-comparison-row__label {
  margin: 0;
  color: var(--text);
  font-size: 0.9rem;
  font-weight: 600;
  line-height: 1.35;
}

.v10-comparison-row__legend {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 7px 12px;
}

.v10-comparison-row__legend-item {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  color: var(--muted);
  font-size: 0.76rem;
  line-height: 1.3;
}

.v10-comparison-row__legend-marker,
.v10-comparison-row__marker {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--v10-tone);
}

.v10-comparison-row__legend-value {
  font-variant-numeric: tabular-nums;
}

.v10-comparison-row__scale {
  display: grid;
  gap: 7px;
  min-width: 0;
}

.v10-comparison-row__end {
  color: var(--muted);
  font-size: 0.76rem;
  line-height: 1.35;
}

.v10-comparison-row__end--high {
  text-align: right;
}

.v10-comparison-row__track {
  position: relative;
  min-width: 0;
  height: 48px;
  border: 1px solid var(--border);
  border-radius: 4px;
  background: var(--panel);
}

.v10-comparison-row__axis {
  position: absolute;
  left: 8px;
  right: 8px;
  top: 50%;
  border-top: 2px solid var(--border);
  transform: translateY(-50%);
}

.v10-comparison-row__marker {
  position: absolute;
  left: clamp(10px, var(--v10-comparison-position, 0%), calc(100% - 10px));
  top: calc(50% + var(--v10-comparison-offset, 0px));
  width: 18px;
  height: 18px;
  transform: translate(-50%, -50%);
}

.v10-comparison-row__poles {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
  min-width: 0;
}

.v10-marker-glyph {
  display: block;
  width: 16px;
  height: 16px;
  overflow: visible;
}

.v10-layer-stack {
  display: grid;
  gap: 12px;
  min-width: 0;
}

.v10-layer-stack__item {
  min-width: 0;
  padding: 16px 18px;
  border: 1px solid var(--border);
  border-left-width: 4px;
  border-radius: 7px;
  background: var(--panel);
}

.v10-layer-stack__item[data-status="anchor"] {
  border-left-color: var(--text);
}

.v10-layer-stack__item[data-status="reinforces"] {
  border-left-color: var(--t-constructivist);
}

.v10-layer-stack__item[data-status="complicates"] {
  border-left-color: var(--t-institutionalist);
}

.v10-layer-stack__item[data-status="diverges"] {
  border-left-color: var(--accent);
}

.v10-layer-stack__item[data-status="pending"] {
  border-style: dashed;
  border-left-color: var(--muted);
}

.v10-layer-stack__meta {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  align-items: center;
}

.v10-layer-stack__label,
.v10-layer-stack__status {
  margin: 0;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  line-height: 1.3;
  text-transform: uppercase;
}

.v10-layer-stack__label {
  color: var(--accent);
}

.v10-layer-stack__status {
  flex-shrink: 0;
  padding: 3px 7px;
  border: 1px solid var(--border);
  border-radius: 4px;
  color: var(--muted);
}

.v10-layer-stack__title {
  margin: 8px 0 0;
  font-size: 1rem;
  line-height: 1.35;
}

.v10-layer-stack__text {
  margin: 6px 0 0;
  color: var(--muted);
  font-size: 0.88rem;
  line-height: 1.6;
}

.v10-layer-stack__action {
  margin-top: 10px;
  font-size: 0.88rem;
}

@media (max-width: 680px) {
  .v10-segmented-level,
  .v10-segmented-level--compact {
    grid-template-columns: 1fr;
  }

  .v10-comparison-row__header,
  .v10-comparison-row__scale {
    grid-template-columns: 1fr;
  }

  .v10-comparison-row__poles {
    grid-template-columns: 1fr;
    gap: 4px;
  }

  .v10-comparison-row__legend {
    justify-content: flex-start;
  }

  .v10-comparison-row__end--high {
    text-align: left;
  }
}

.lobby-note-band {
  padding: 16px 18px;
  border: 1px solid var(--border-soft);
  border-radius: 8px;
  background: color-mix(in srgb, var(--panel) 86%, white 14%);
}

.lobby-note-title {
  margin: 0;
  font-weight: 700;
  color: var(--text);
}

.module-choice-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 22px;
}

.module-choice-card {
  min-width: 0;
  padding: 24px;
  border: 1px solid var(--border-soft);
  border-radius: 8px;
  background: color-mix(in srgb, var(--panel) 88%, white 12%);
}

.module-choice-meta {
  margin: 0;
  display: grid;
  gap: 14px;
  padding-top: 16px;
  border-top: 1px solid var(--line);
}

.module-choice-meta dt {
  margin: 0 0 4px;
  font-size: 0.76rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--accent);
}

.module-choice-meta dd {
  margin: 0;
  color: var(--muted);
