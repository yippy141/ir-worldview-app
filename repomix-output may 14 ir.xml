            <span class="grid" style="left:66.66%"></span>
            <span class="grid" style="left:83.33%"></span>
            <div class="d3-seg">
              <span class="fill" style="left:50%; width:30%"></span>
              <span class="tip" style="left:calc(50% + 30% + 8px)">+1.8 · competition</span>
            </div>
            <div class="lane-meta">
              <span>Source: Security &amp; Strategy module · n = 12 items</span>
              <span class="delta">Δ +1.8</span>
            </div>
          </div>
        </div>

        <!-- Institutions: -0.5 left -->
        <div class="d3-row">
          <div class="label">
            <div class="nm">Institutions and rules</div>
            <div class="anchor">baseline 5.8 / 7 · pressure 5.3 / 7</div>
          </div>
          <div class="d3-bar">
            <span class="grid" style="left:16.66%"></span>
            <span class="grid" style="left:33.33%"></span>
            <span class="axis"></span>
            <span class="grid" style="left:66.66%"></span>
            <span class="grid" style="left:83.33%"></span>
            <div class="d3-seg">
              <span class="fill" style="left:41.66%; width:8.34%"></span>
              <span class="tip" style="right:calc(50% + 8.34% + 8px); left:auto">−0.5 · skeptical</span>
            </div>
            <div class="lane-meta">
              <span>Source: Tech &amp; Geoeconomics module · n = 9 items</span>
              <span class="delta">Δ −0.5</span>
            </div>
          </div>
        </div>

        <!-- Legitimacy: stable +0.2 -->
        <div class="d3-row stable">
          <div class="label">
            <div class="nm">Legitimacy of rule-setting</div>
            <div class="anchor">baseline 4.5 / 7 · pressure 4.7 / 7 · stable</div>
          </div>
          <div class="d3-bar">
            <span class="grid" style="left:16.66%"></span>
