<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>AI Field Guide — 2 Directions</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  :root {
    --paper: #f5f1e8;
    --paper-2: #efe9dc;
    --paper-3: #e9e1ce;
    --ink: #1a1916;
    --ink-2: #3a362e;
    --muted: #6b6356;
    --rule: #d8cfbb;
    --rule-strong: #a89b80;
    --accent: #7a2e1f;
    --accent-2: #8a6b1d;
    --accent-3: #2f5d3a;
    --accent-4: #1f3a5f;
  }
  * { box-sizing: border-box; }
  html, body {
    background: #ddd5c0;
    color: var(--ink);
    margin: 0; padding: 0;
    font-family: "Source Serif 4", "Iowan Old Style", Georgia, serif;
    font-size: 16px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }
  .showcase { max-width: 1480px; margin: 0 auto; padding: 56px 32px 96px; }
  .show-head {
    border-top: 3px solid var(--ink);
    border-bottom: 1px solid var(--rule-strong);
    padding: 14px 0 10px;
    display: flex;
    justify-content: space-between;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-2);
  }
  .show-title {
    margin: 28px 0 6px;
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .show-deck { color: var(--ink-2); max-width: 720px; margin: 0 0 32px; }

  .dir-label {
    display: flex; align-items: baseline; gap: 18px; margin: 56px 0 10px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted);
  }
  .dir-label .num { font-family: "IBM Plex Mono", monospace; color: var(--ink-2); }
  .dir-label .name { color: var(--ink); font-weight: 700; letter-spacing: 0.08em; }
  .dir-rationale {
    background: var(--paper-2); border: 1px solid var(--rule); border-left: 3px solid var(--ink);
    padding: 14px 18px 14px 22px; margin: 0 0 18px; max-width: 1100px;
    font-size: 14.5px; color: var(--ink-2);
  }
  .dir-rationale b {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); display: block; margin-bottom: 4px; font-weight: 700;
  }

  .frame {
    background: var(--paper); border: 1px solid var(--rule-strong);
    box-shadow: 0 1px 0 rgba(0,0,0,0.04), 0 18px 40px -28px rgba(40,30,10,0.25);
  }
  .nav {
    border-bottom: 1px solid var(--rule); padding: 14px 56px;
    display: flex; align-items: center; justify-content: space-between;
    font-family: "IBM Plex Sans", system-ui, sans-serif; font-size: 12.5px; color: var(--ink-2);
  }
  .brand { font-family: "Source Serif 4", Georgia, serif; font-weight: 700; font-size: 15px; color: var(--ink); }
  .brand .beta { margin-left: 8px; font-family: "IBM Plex Mono", monospace; font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--muted); font-weight: 500; }
  .nav-links { display: flex; gap: 24px; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; }
  .nav-links a { color: var(--ink-2); text-decoration: none; padding-bottom: 2px; border-bottom: 1px solid transparent; }
  .nav-links a.active { color: var(--ink); border-bottom-color: var(--ink); font-weight: 600; }
  .frame-inner { padding: 32px 56px 44px; }

  .eyebrow {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--muted); font-weight: 700; margin: 0 0 10px;
  }
  .eyebrow .sep { margin: 0 8px; color: var(--rule-strong); }
  h1.title {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 38px; line-height: 1.08; font-weight: 700;
    letter-spacing: -0.012em; text-wrap: balance; margin: 0 0 12px; max-width: 880px;
  }
  h1.title em { font-style: italic; color: var(--ink-2); font-weight: 600; }
  .deck-line { font-size: 16.5px; color: var(--ink-2); max-width: 720px; margin: 0 0 22px; }

  .non-score-banner {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 6px 12px;
    background: var(--paper-2);
    border: 1px solid var(--rule-strong);
    border-left: 3px solid var(--accent-4);
    margin-bottom: 18px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11.5px; color: var(--ink-2); letter-spacing: 0.04em;
  }
  .non-score-banner b {
    font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent-4);
  }

  /* section heading */
  h2.sec {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 22px; font-weight: 700; letter-spacing: -0.005em;
    margin: 36px 0 4px;
  }
  h2.sec .num {
    font-family: "IBM Plex Mono", monospace;
    font-size: 13px; color: var(--muted); margin-right: 12px; font-weight: 500;
  }
  .sec-deck {
    font-size: 14.5px; color: var(--ink-2); font-style: italic; margin: 0 0 16px; max-width: 720px;
  }

  /* ---------- DIRECTION 01 — Reading Room ---------- */
  /* Editorial spread: 8-axis index + parts-ways pairs + IR↔AI table + start-here shelf, optional futures */

  .d1-axes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--rule-strong);
    border-left: 1px solid var(--rule-strong);
  }
  .d1-axis {
    padding: 14px 16px 14px;
    border-right: 1px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule-strong);
  }
  .d1-axis .num {
    font-family: "IBM Plex Mono", monospace;
    font-size: 10.5px; color: var(--muted); letter-spacing: 0.06em;
  }
  .d1-axis .nm {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 16px; font-weight: 700; margin: 2px 0 6px; letter-spacing: -0.005em;
  }
  .d1-axis .poles {
    font-family: "IBM Plex Mono", monospace;
    font-size: 10.5px; color: var(--muted); letter-spacing: 0.04em; margin-bottom: 6px;
  }
  .d1-axis .desc {
    font-size: 13px; color: var(--ink-2); line-height: 1.45;
  }

  .d1-parts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--rule-strong);
    border-left: 1px solid var(--rule-strong);
  }
  .d1-part {
    padding: 16px 18px;
    border-right: 1px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule-strong);
    background: var(--paper);
  }
  .d1-part .pair {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); font-weight: 700; margin-bottom: 4px;
  }
  .d1-part h4 {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 17px; font-weight: 700; letter-spacing: -0.005em; margin: 0 0 8px;
  }
  .d1-part .splits {
    border-top: 1px solid var(--rule); padding-top: 8px; font-size: 13.5px; color: var(--ink-2); line-height: 1.5;
  }
  .d1-part .splits b {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); display: block; margin-bottom: 2px;
  }

  .d1-cross {
    border: 1px solid var(--rule-strong);
    overflow: hidden;
  }
  .d1-cross-row {
    display: grid; grid-template-columns: 200px 1fr 1fr;
    border-bottom: 1px solid var(--rule);
  }
  .d1-cross-row:last-child { border-bottom: 0; }
  .d1-cross-row.head {
    background: var(--paper-2);
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); font-weight: 700;
  }
  .d1-cross-row > div {
    padding: 12px 16px; border-right: 1px solid var(--rule);
    font-size: 13.5px; line-height: 1.5; color: var(--ink-2);
  }
  .d1-cross-row > div:last-child { border-right: 0; }
  .d1-cross-row .key {
    font-family: "Source Serif 4", Georgia, serif; color: var(--ink); font-weight: 600; font-size: 14.5px;
  }

  .d1-start {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule-strong);
    border-left: 1px solid var(--rule-strong);
  }
  .d1-start-cell {
    padding: 16px 18px;
    border-right: 1px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule-strong);
    background: var(--paper);
  }
  .d1-start-cell .lbl {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); font-weight: 700; margin-bottom: 6px;
  }
  .d1-start-cell h4 {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 16px; font-weight: 700; letter-spacing: -0.005em; margin: 0 0 6px;
  }
  .d1-start-cell p { font-size: 13px; color: var(--ink-2); line-height: 1.5; margin: 0 0 8px; }
  .d1-start-cell a {
    font-family: "IBM Plex Mono", monospace; font-size: 11px;
    color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--ink); padding-bottom: 1px;
  }

  .d1-futures {
    margin-top: 22px;
    border: 1px dashed var(--rule-strong);
    background: transparent;
    padding: 14px 18px;
    color: var(--ink-2);
    font-size: 13.5px;
    line-height: 1.5;
  }
  .d1-futures .lbl {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted); font-weight: 700; margin-bottom: 4px;
    display: flex; gap: 10px; align-items: center;
  }
  .d1-futures .lbl .pill {
    background: var(--paper-2); border: 1px solid var(--rule-strong);
    padding: 2px 7px; border-radius: 999px; font-size: 9.5px; letter-spacing: 0.08em;
    color: var(--muted);
  }

  /* ---------- DIRECTION 02 — Two-Column Explainer ---------- */
  /* Sticky left rail with sections; right column is the content */

  .d2-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 36px;
    align-items: start;
  }
  .d2-rail {
    border-right: 1px solid var(--rule);
    padding-right: 20px;
    position: sticky;
    top: 24px;
  }
  .d2-rail .lbl {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted); font-weight: 700; margin-bottom: 10px;
  }
  .d2-rail ol {
    list-style: none; padding: 0; margin: 0; counter-reset: rl;
  }
  .d2-rail ol li {
    counter-increment: rl;
    border-bottom: 1px dotted var(--rule);
    padding: 9px 0 9px 30px;
    position: relative;
    font-size: 13.5px; color: var(--ink); font-family: "Source Serif 4", Georgia, serif;
    letter-spacing: -0.005em;
  }
  .d2-rail ol li::before {
    content: counter(rl, decimal-leading-zero);
    position: absolute; left: 0; top: 11px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px; color: var(--muted);
  }
  .d2-rail ol li.active { color: var(--accent); font-weight: 700; }
  .d2-rail ol li.active::before { color: var(--accent); }
  .d2-rail ol li.optional {
    color: var(--muted); font-style: italic;
  }
  .d2-rail ol li.optional::after {
    content: "optional";
    margin-left: 8px;
    font-family: "IBM Plex Sans", monospace;
    font-style: normal;
    font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--rule-strong);
    padding: 1px 5px; border-radius: 999px;
    background: var(--paper-2);
  }
  .d2-rail .legend {
    margin-top: 18px;
    padding: 10px 12px;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px;
    color: var(--ink-2); line-height: 1.5;
  }
  .d2-rail .legend b { font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); display: block; margin-bottom: 4px; font-weight: 700; }

  .d2-content > section { margin-bottom: 38px; }

  /* 8 axes — paired-pole row */
  .d2-axes-list {
    border-top: 1px solid var(--rule-strong);
  }
  .d2-axis {
    display: grid;
    grid-template-columns: 30px 1fr 200px;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid var(--rule);
    align-items: center;
  }
  .d2-axis .n {
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px; color: var(--muted); letter-spacing: 0.04em;
  }
  .d2-axis .body .nm {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 16.5px; font-weight: 700; letter-spacing: -0.005em; margin-bottom: 1px;
  }
  .d2-axis .body .desc {
    font-size: 13px; color: var(--ink-2); line-height: 1.5;
  }
  .d2-axis .poles {
    text-align: right;
  }
  .d2-axis .poles .row {
    display: flex; justify-content: flex-end; gap: 8px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 10.5px; color: var(--muted); letter-spacing: 0.04em;
  }
  .d2-axis .poles .scale {
    margin-top: 4px;
    height: 4px;
    border: 1px solid var(--rule-strong);
    background: linear-gradient(to right, var(--paper-3), var(--paper-2));
  }

  /* parts-ways pairs as ruled rows */
  .d2-parts-row {
    display: grid;
    grid-template-columns: 200px 1fr 1fr;
    gap: 0;
    border-bottom: 1px solid var(--rule);
  }
  .d2-parts-row:first-of-type { border-top: 1px solid var(--rule-strong); }
  .d2-parts-row.head {
    background: var(--paper-2);
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); font-weight: 700;
  }
  .d2-parts-row > div { padding: 12px 14px; border-right: 1px solid var(--rule); }
  .d2-parts-row > div:last-child { border-right: 0; }
  .d2-parts-row .pair {
    font-family: "Source Serif 4", Georgia, serif; font-size: 14.5px; font-weight: 600; letter-spacing: -0.005em; color: var(--ink);
  }
  .d2-parts-row .pair small { display: block; font-family: "IBM Plex Sans", monospace; font-size: 10.5px; letter-spacing: 0.04em; color: var(--muted); font-weight: 500; margin-top: 2px; }
  .d2-parts-row .col {
    font-size: 13.5px; line-height: 1.5; color: var(--ink-2);
  }
  .d2-parts-row .col b {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--accent); display: block; margin-bottom: 2px; font-weight: 700;
  }

  /* cross-read mini-grid */
  .d2-cross {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule-strong);
    border-left: 1px solid var(--rule-strong);
  }
  .d2-cross-cell {
    padding: 14px 16px;
    border-right: 1px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule-strong);
    background: var(--paper);
  }
  .d2-cross-cell .ir {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent-4); font-weight: 700;
  }
  .d2-cross-cell h5 {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 15px; font-weight: 700; letter-spacing: -0.005em; margin: 4px 0 6px;
  }
  .d2-cross-cell .desc { font-size: 13px; color: var(--ink-2); line-height: 1.5; }
  .d2-cross-cell .ai {
    margin-top: 8px; padding-top: 8px; border-top: 1px dashed var(--rule);
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px; color: var(--ink); letter-spacing: 0.02em;
  }
  .d2-cross-cell .ai b { color: var(--accent); font-weight: 600; }

  /* start-here */
  .d2-start {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 14px;
  }
  .d2-start-cell {
    padding: 14px 16px;
    border: 1px solid var(--rule-strong);
    background: var(--paper);
  }
  .d2-start-cell .lbl {
