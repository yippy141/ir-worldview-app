<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Profile Desktop — 3 Directions</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  :root {
    --paper: #f5f1e8;
    --paper-2: #efe9dc;
    --paper-3: #e9e1ce;
    --ink: #1a1916;
    --ink-2: #3a362e;
    --muted: #6b6356;
    --rule: #d8cfbb;
    --rule-strong: #a89b80;
    --accent: #7a2e1f;
    --accent-2: #8a6b1d;
    --accent-3: #2f5d3a;
    --accent-4: #1f3a5f;
    --tag-bg: #e9e1ce;
  }
  * { box-sizing: border-box; }
  html, body {
    background: #ddd5c0;
    color: var(--ink);
    margin: 0;
    padding: 0;
    font-family: "Source Serif 4", "Iowan Old Style", Georgia, serif;
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* Showcase shell */
  .showcase {
    max-width: 1480px;
    margin: 0 auto;
    padding: 56px 32px 96px;
  }
  .showcase-head {
    border-top: 3px solid var(--ink);
    border-bottom: 1px solid var(--rule-strong);
    padding: 14px 0 10px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-2);
  }
  .showcase-title {
    margin: 32px 0 6px;
    font-size: 38px;
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .showcase-deck {
    color: var(--ink-2);
    font-size: 17px;
    max-width: 720px;
    margin: 0 0 48px;
    text-wrap: pretty;
  }

  .dir-label {
    display: flex;
    align-items: baseline;
    gap: 18px;
    margin: 56px 0 14px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .dir-label .num {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    color: var(--ink-2);
  }
  .dir-label .name {
    color: var(--ink);
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .dir-rationale {
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--ink);
    padding: 14px 18px 14px 22px;
    margin: 0 0 18px;
    max-width: 1100px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-2);
  }
  .dir-rationale b {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-bottom: 4px;
    font-weight: 700;
  }

  /* ---------- Profile frame (shared) ---------- */
  .frame {
    background: var(--paper);
    border: 1px solid var(--rule-strong);
    box-shadow: 0 1px 0 rgba(0,0,0,0.04), 0 18px 40px -28px rgba(40,30,10,0.25);
    margin: 0 0 12px;
    overflow: hidden;
  }
  .frame-inner { padding: 36px 56px 44px; }

  .nav {
    border-bottom: 1px solid var(--rule);
    padding: 14px 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12.5px;
    color: var(--ink-2);
    background: var(--paper);
  }
  .nav .brand {
    font-family: "Source Serif 4", Georgia, serif;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.005em;
    color: var(--ink);
  }
  .nav .brand .beta {
    margin-left: 8px;
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    font-weight: 500;
  }
  .nav-links {
    display: flex;
    gap: 24px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .nav-links a {
    color: var(--ink-2);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
  }
  .nav-links a.active {
    color: var(--ink);
    border-bottom-color: var(--ink);
    font-weight: 600;
  }
  .nav .meta-r {
    color: var(--muted);
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .eyebrow {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 700;
    margin: 0 0 12px;
  }
  .eyebrow .sep {
    margin: 0 8px;
    color: var(--rule-strong);
  }

  .h-title {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 40px;
    line-height: 1.08;
    font-weight: 700;
    letter-spacing: -0.012em;
    text-wrap: balance;
    margin: 0 0 14px;
    max-width: 880px;
  }
  .h-title em {
    font-style: italic;
    color: var(--ink-2);
    font-weight: 600;
  }
  .summary {
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 720px;
    text-wrap: pretty;
    margin: 0 0 22px;
  }

  /* Stat / fact chips */
  .chips {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin: 0 0 26px;
  }
  .chip {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    padding: 7px 12px 8px;
    background: var(--paper-2);
    border: 1px solid var(--rule-strong);
    border-radius: 2px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12px;
    color: var(--ink-2);
  }
  .chip .k {
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-size: 10.5px;
    color: var(--muted);
    font-weight: 700;
  }
  .chip .v {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 14px;
    color: var(--ink);
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .chip.high .v { color: var(--accent); }
  .chip.med .v { color: var(--accent-2); }
  .chip.low .v { color: var(--accent-3); }
  .chip.struct .v { color: var(--accent-4); }

  /* CTA row */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
    padding-top: 22px;
    border-top: 1px solid var(--rule);
  }
  .cta {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12.5px;
    letter-spacing: 0.04em;
    padding: 10px 16px;
    border-radius: 2px;
    border: 1px solid var(--rule-strong);
    background: var(--paper-2);
    color: var(--ink);
    text-decoration: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    line-height: 1.2;
    font-weight: 500;
  }
  .cta .arr {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    color: var(--muted);
    font-size: 12px;
  }
  .cta.primary {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
    font-weight: 600;
  }
  .cta.primary .arr { color: var(--paper-3); }
  .cta:hover { border-color: var(--ink); }

  /* ----- Direction 01: Strip Atlas (stacked horizontal scales) ----- */
  .d1-chart {
    margin: 6px 0 4px;
    border-top: 1px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule-strong);
    background: #faf6ea;
  }
  .d1-axis {
    display: grid;
    grid-template-columns: 220px 1fr 110px;
    align-items: center;
    border-bottom: 1px solid var(--rule);
    padding: 14px 0;
  }
  .d1-axis:last-child { border-bottom: 0; }
  .d1-axis .lane {
    padding: 0 18px 0 22px;
  }
  .d1-axis .lane .nm {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .d1-axis .lane .poles {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 10.5px;
    color: var(--muted);
    margin-top: 2px;
    letter-spacing: 0.04em;
  }
  .d1-track {
    position: relative;
    height: 28px;
    margin: 0 22px;
    border-bottom: 1px solid var(--rule);
  }
  .d1-track::before, .d1-track::after, .d1-track .mid {
    position: absolute;
    bottom: 0;
    width: 1px;
    background: var(--rule-strong);
    height: 6px;
  }
  .d1-track::before { left: 0; }
  .d1-track::after { right: 0; }
  .d1-track .mid { left: 50%; height: 4px; background: var(--rule); }
  .d1-track .tick {
    position: absolute;
    bottom: 0;
    width: 1px;
    height: 3px;
    background: var(--rule);
  }
  .d1-base, .d1-pres {
    position: absolute;
    top: 6px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .d1-base .dot {
    width: 11px; height: 11px;
    border-radius: 50%;
    background: var(--paper);
    border: 1.5px solid var(--ink);
  }
  .d1-pres .dot {
    width: 11px; height: 11px;
    border-radius: 50%;
    background: var(--accent);
    border: 1.5px solid var(--accent);
  }
  .d1-base .lbl, .d1-pres .lbl {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 9.5px;
    color: var(--muted);
    margin-top: 3px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .d1-pres .lbl { color: var(--accent); font-weight: 600; }
  .d1-link {
    position: absolute;
    top: 11px;
    height: 1px;
    background: var(--accent);
    opacity: 0.5;
  }
  .d1-axis .delta {
    text-align: right;
    padding-right: 22px;
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 11px;
    color: var(--ink-2);
    letter-spacing: 0.02em;
  }
  .d1-axis .delta .v {
    font-size: 13px;
    color: var(--accent);
    font-weight: 600;
  }
  .d1-axis.stable .delta .v { color: var(--accent-3); }
  .d1-axis.stable .d1-pres .dot { background: var(--accent-3); border-color: var(--accent-3); }
  .d1-axis.stable .d1-link { background: var(--accent-3); }
  .d1-axis.stable .d1-pres .lbl { color: var(--accent-3); }

  .d1-legend {
    display: flex;
    gap: 22px;
    align-items: center;
    padding: 10px 22px;
    background: var(--paper-2);
    border-top: 1px solid var(--rule);
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .d1-legend .sw {
    display: inline-block;
    width: 10px; height: 10px;
    border-radius: 50%;
    margin-right: 6px;
    vertical-align: -1px;
  }
  .d1-legend .sw.base { background: var(--paper); border: 1.5px solid var(--ink); }
  .d1-legend .sw.pres { background: var(--accent); border: 1.5px solid var(--accent); }
  .d1-legend .sw.stable { background: var(--accent-3); border: 1.5px solid var(--accent-3); }
  .d1-legend .right { margin-left: auto; font-family: "IBM Plex Mono", ui-monospace, monospace; letter-spacing: 0.04em; text-transform: none; }

  .d1-aiband {
    margin-top: 18px;
    padding: 12px 18px;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--accent-4);
    display: flex;
    align-items: baseline;
    gap: 18px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12.5px;
    color: var(--ink-2);
  }
  .d1-aiband .lbl {
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--accent-4);
    flex: 0 0 auto;
  }
  .d1-aiband .body {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--ink);
  }
  .d1-aiband .open {
    margin-left: auto;
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 11.5px;
    color: var(--accent-4);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-4);
    padding-bottom: 1px;
    flex: 0 0 auto;
  }

  /* ----- Direction 02: Then / Now Overlay (single ridge chart) ----- */
  .d2-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .d2-left .summary { margin-bottom: 18px; }
  .d2-chart-wrap {
    border: 1px solid var(--rule-strong);
    background: #faf6ea;
    padding: 20px 24px 18px;
  }
  .d2-chart-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 14px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .d2-chart-head .t {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 15px;
    text-transform: none;
    letter-spacing: -0.005em;
    color: var(--ink);
    font-weight: 700;
  }
  .d2-svg {
    display: block;
    width: 100%;
    height: 280px;
  }
  .d2-axis-labels {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    margin-top: 6px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
    border-top: 1px solid var(--rule-strong);
    padding-top: 8px;
  }
  .d2-axis-labels span { font-weight: 600; color: var(--ink-2); }
  .d2-legend {
    display: flex;
    gap: 22px;
    margin-top: 14px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-top: 1px solid var(--rule);
    padding-top: 12px;
  }
  .d2-legend .ln {
    display: inline-block;
    width: 22px; height: 0;
    margin-right: 8px;
    vertical-align: 4px;
    border-top: 1.5px solid var(--ink);
  }
  .d2-legend .ln.pres { border-top: 1.5px solid var(--accent); border-top-style: dashed; }
  .d2-callout {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px dashed var(--rule);
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-2);
  }
