<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Red Team Memo — IR Worldview Inventory</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  :root {
    --paper: #f5f1e8;
    --paper-2: #efe9dc;
    --ink: #1a1916;
    --ink-2: #3a362e;
    --muted: #6b6356;
    --rule: #d8cfbb;
    --rule-strong: #a89b80;
    --accent: #7a2e1f;     /* oxblood — for severity High */
    --accent-2: #8a6b1d;   /* ochre — Medium */
    --accent-3: #2f5d3a;   /* forest — Low / nice-to-have */
    --accent-4: #1f3a5f;   /* navy — Structural */
    --tag-bg: #e9e1ce;
    --callout-bg: #ece4d0;
    --callout-edge: #b8a984;
  }

  * { box-sizing: border-box; }
  html, body { background: var(--paper); color: var(--ink); }
  body {
    font-family: "Source Serif 4", "Iowan Old Style", Georgia, serif;
    font-size: 17px;
    line-height: 1.62;
    margin: 0;
    padding: 0;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  .page {
    max-width: 820px;
    margin: 0 auto;
    padding: 72px 56px 120px;
  }

  .masthead {
    border-top: 3px solid var(--ink);
    border-bottom: 1px solid var(--rule-strong);
    padding: 14px 0 10px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-2);
  }
  .masthead .right { color: var(--muted); }

  .doc-title {
    margin: 36px 0 8px;
    font-size: 44px;
    line-height: 1.08;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .doc-sub {
    font-size: 19px;
    color: var(--ink-2);
    line-height: 1.45;
    max-width: 640px;
    text-wrap: pretty;
    margin: 0 0 28px;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 6px 24px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12.5px;
    color: var(--ink-2);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 14px 0;
    margin-bottom: 36px;
  }
  .meta-grid dt {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    font-size: 11px;
    padding-top: 2px;
  }
  .meta-grid dd {
    margin: 0;
    line-height: 1.45;
  }

  /* Section structure */
  h2 {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 28px;
    line-height: 1.18;
    font-weight: 700;
    letter-spacing: -0.005em;
    margin: 56px 0 6px;
    text-wrap: balance;
  }
  h2 .num {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 14px;
    color: var(--muted);
    margin-right: 14px;
    font-weight: 500;
    letter-spacing: 0;
    vertical-align: 4px;
  }
  h2 + .deck {
    color: var(--ink-2);
    font-size: 17px;
    margin: 0 0 24px;
    line-height: 1.55;
    font-style: italic;
    max-width: 640px;
  }
  h3 {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 21px;
    font-weight: 700;
    line-height: 1.25;
    margin: 36px 0 4px;
    text-wrap: balance;
  }

  .section-rule {
    border: 0;
    border-top: 1px solid var(--rule-strong);
    margin: 56px 0 0;
  }

  p { margin: 0 0 14px; text-wrap: pretty; }
  p + p { margin-top: 0; }

  /* Drop cap on the first paragraph after the lead */
  .lead p:first-of-type::first-letter {
    font-family: "Source Serif 4", Georgia, serif;
    font-weight: 700;
    font-size: 56px;
    line-height: 0.86;
    float: left;
    padding: 6px 8px 0 0;
    color: var(--ink);
  }

  /* Severity / category chips on findings */
  .finding {
    margin: 18px 0 28px;
    padding: 18px 20px 18px 22px;
    background: #fbf7ec;
    border: 1px solid var(--rule);
    border-left: 4px solid var(--rule-strong);
    border-radius: 2px;
  }
  .finding.high { border-left-color: var(--accent); }
  .finding.med  { border-left-color: var(--accent-2); }
  .finding.low  { border-left-color: var(--accent-3); }
  .finding.struct { border-left-color: var(--accent-4); }

  .finding-head {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin-bottom: 6px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .chip {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--ink-2);
    font-weight: 600;
    letter-spacing: 0.08em;
    font-size: 10.5px;
    border: 1px solid var(--rule-strong);
  }
  .chip.high   { background: #f5dad2; color: #6e2516; border-color: #d59c8b; }
  .chip.med    { background: #f0e3bd; color: #6a510f; border-color: #cdb672; }
  .chip.low    { background: #d8e6d6; color: #234e2c; border-color: #91b29a; }
  .chip.struct { background: #d6def0; color: #1a3354; border-color: #8ea0c4; }

  .finding h4 {
    margin: 0 0 8px;
    font-size: 18px;
    line-height: 1.3;
    font-weight: 700;
    text-wrap: balance;
  }
  .finding p { margin-bottom: 10px; }
  .finding p:last-child { margin-bottom: 0; }
  .finding .fix {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px dashed var(--rule);
    font-size: 15.5px;
  }
  .finding .fix b {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    font-weight: 600;
    display: block;
    margin-bottom: 4px;
  }

  /* Pull quote / lifted phrase */
  blockquote {
    margin: 18px 0;
    padding: 4px 0 4px 20px;
    border-left: 3px solid var(--rule-strong);
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.55;
  }
  blockquote .src {
    display: block;
    margin-top: 6px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Two-column layout for "the strongest objection" boxes */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin: 18px 0;
  }
  .two-col .col {
    padding: 14px 16px;
    background: var(--callout-bg);
    border: 1px solid var(--callout-edge);
    border-radius: 2px;
  }
  .two-col .col h5 {
    margin: 0 0 6px;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    font-weight: 700;
  }
  .two-col .col p { font-size: 15.5px; line-height: 1.55; margin: 0; }

  /* Compact lists with hanging numerals */
  ol.hang {
    counter-reset: item;
    list-style: none;
    padding: 0;
    margin: 16px 0 22px;
  }
  ol.hang > li {
    counter-increment: item;
    position: relative;
    padding: 0 0 0 38px;
    margin-bottom: 14px;
    line-height: 1.55;
  }
  ol.hang > li::before {
    content: counter(item, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 2px;
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0;
  }

