              <span class="tip" style="left:calc(50% + 3.33% + 8px); color:#3a362e">+0.2 · within band</span>
            </div>
            <div class="lane-meta">
              <span>All three modules · n = 14 items</span>
              <span class="delta">Δ +0.2</span>
            </div>
          </div>
        </div>

        <!-- Political econ: +1.1 right -->
        <div class="d3-row">
          <div class="label">
            <div class="nm">Political economy</div>
