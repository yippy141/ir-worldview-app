          </div>
          <div class="d3-bar">
            <span class="grid" style="left:16.66%"></span>
            <span class="grid" style="left:33.33%"></span>
            <span class="axis"></span>
            <span class="grid" style="left:66.66%"></span>
            <span class="grid" style="left:83.33%"></span>
            <div class="d3-seg">
              <span class="fill" style="left:50%; width:18.33%"></span>
              <span class="tip" style="left:calc(50% + 18.33% + 8px)">+1.1 · dependence</span>
            </div>
            <div class="lane-meta">
              <span>Source: Tech &amp; Geoeconomics module · n = 11 items</span>
              <span class="delta">Δ +1.1</span>
            </div>
          </div>
        </div>

        <!-- Oversight: stable -0.1 -->
        <div class="d3-row stable">
          <div class="label">
