  }

  .ai-atlas-fingerprint-card__cta {
    margin-left: 0;
  }

  .likert-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .header-inner {
    align-items: center;
    gap: 16px;
    padding: 18px 0 16px;
  }

  .site-brand-link {
    min-width: 0;
    flex: 1 1 auto;
  }

  .reading-path-header {
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .reading-path-related {
    padding-top: 12px;
    padding-left: 0;
    border-top: 1px solid var(--line);
    border-left: none;
  }

  .header-nav--desktop {
    display: none;
  }

  .mobile-nav {
    display: block;
    flex: 0 0 auto;
  }

  .mobile-nav-summary {
    width: auto;
    min-width: 96px;
  }

  .quiz-shell-inner {
    grid-template-columns: 1fr;
    gap: 10px;
    padding: 14px 0;
  }

  .quiz-shell-heading {
    order: 1;
  }

  .quiz-shell-actions {
    order: 2;
    justify-self: stretch;
    justify-content: center;
    flex-direction: column;
    align-items: center;
  }

  .quiz-shell-brand-link {
    order: 3;
    justify-self: center;
  }

  .quiz-shell-steps {
    justify-content: center;
  }

  .quiz-shell-exit {
    justify-content: center;
    width: 100%;
    max-width: 220px;
  }

  .quiz-shell-main {
    padding-top: 28px;
  }

  .panel {
    padding: 20px;
  }

  .module-linkage-panel {
    padding: 20px;
  }

  .module-mode-grid,
  .module-card-grid,
  .module-meta-grid,
  .module-lane-grid,
  .module-linkage-grid,
  .module-relation-grid {
    grid-template-columns: 1fr;
  }

  .driver-grid {
    grid-template-columns: 1fr;
  }

  .result-signature-meta {
    grid-template-columns: 1fr;
  }

  .ai-result-overview,
  .ai-result-summary-grid,
  .ai-result-policy-grid,
  .ai-result-columns,
  .ai-result-tension-grid,
  .ai-result-critique-grid {
    grid-template-columns: 1fr;
  }

  .neighbor-columns {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .family-fit-row {
    grid-template-columns: 140px 1fr auto;
    gap: 8px;
  }

  .explore-grid {
    grid-template-columns: 1fr;
  }

  .atlas-layout {
    grid-template-columns: 1fr;
  }

  .atlas-toc {
    position: static;
    display: none;
  }

  .atlas-detail-hero-grid,
  .atlas-detail-columns {
    grid-template-columns: 1fr;
  }

  .compare-form-grid,
  .compare-summary-grid,
  .compare-spine-row {
    grid-template-columns: 1fr;
  }

  .atlas-fingerprint-row,
  .atlas-fingerprint--compact .atlas-fingerprint-row {
    grid-template-columns: 1fr;
  }

  .atlas-fingerprint .v10-segmented-level__value {
    text-align: left;
  }

  .compare-grid {
    grid-template-columns: 1fr 1fr;
  }

  .landing-hero {
    padding: 42px 0 36px;
  }

  .landing-section {
    padding: 42px 0;
  }

  .landing-display {
    max-width: none;
    font-size: clamp(1.9rem, 9vw, 2.7rem);
  }

  .landing-action-row {
    flex-direction: column;
    align-items: flex-start;
  }

  .landing-quick-grid {
    grid-template-columns: 1fr;
  }

  .landing-rail-link {
    grid-template-columns: 1fr;
  }

  .landing-rail-meta {
    align-items: flex-start;
    text-align: left;
  }

  .article-header {
    padding: 32px 0 26px;
  }

  .lobby-hero {
    padding: 44px 0 30px;
  }

  .article-section {
    padding: 30px 0;
  }

  .result-hero {
    padding: 40px 0 32px;
  }

  .profile-hero {
    padding: 40px 0 32px;
  }

  .ai-bridge-panel {
    padding: 20px;
  }

  .result-section {
    padding: 32px 0;
  }

  .ai-result-overview {
    gap: 16px;
  }

  .ai-result-lead-card,
  .ai-result-card {
    padding: 18px;
    border-radius: 6px;
  }

  .ai-result-lead {
    font-size: 1rem;
    line-height: 1.8;
  }

  .ai-result-metric {
    font-size: 1.72rem;
  }

  .ai-result-question {
    font-size: 1rem;
    line-height: 1.8;
  }

  .compare-spine-scale {
    grid-template-columns: 1fr;
    gap: 8px;
  }
}

/* ── AI Governance Compass — visual system polish ────────────────────────────
   All classes here are prefixed .ai- and do not affect IR routes.
   ─────────────────────────────────────────────────────────────────────────── */

/* Hero rule: shorter, bolder, policy-doc weight */
.ai-hero-rule {
  height: 4px;
  width: 48px;
  border-radius: 2px;
  margin-bottom: 36px;
  background: var(--accent);
}

.ai-result-hero {
  display: grid;
  grid-template-columns: 1fr;
  gap: 26px;
  align-items: start;
}

.ai-result-hero::before {
  content: none;
}

.ai-result-hero__copy {
  min-width: 0;
}

.ai-result-hero__signals {
  min-width: 0;
  padding: 20px 22px;
  border: 1px solid var(--border);
  border-radius: 7px;
  background: var(--panel);
}

.ai-result-hero__bars {
  display: grid;
  gap: 13px;
  margin-top: 12px;
}

@media (min-width: 980px) {
  .ai-result-hero {
    grid-template-columns: minmax(0, 1.12fr) minmax(300px, 0.88fr);
    gap: 42px;
  }
}

/* Modifier chips: policy-doc style — no pill radius, clean border */
.ai-modifier-chip {
  display: inline-block;
  padding: 3px 9px;
  font-size: 0.71rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  border: 1px solid var(--border);
  border-radius: 3px;
  color: var(--muted);
  background: var(--panel-2);
  white-space: nowrap;
}

/* Wider card padding for AI result cards */
.ai-result-lead-card,
.ai-result-card {
  padding: 24px 28px;
}

/* Reading list bucket — border separator between consecutive buckets */
.ai-reading-bucket + .ai-reading-bucket {
  padding-top: 28px;
  border-top: 1px solid var(--border);
}

/* Mode pill — more defined for AI quiz */
.ai-mode-pill {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border: 1px solid var(--border);
  border-left: 2px solid var(--accent);
  background: var(--panel-2);
  border-radius: 3px;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--accent);
}

/* Axis row: slightly more breathing room than dim-row */
.ai-dim-row {
  padding: 18px 0;
  border-bottom: 1px solid var(--border);
}

.ai-dim-row:last-child {
  border-bottom: none;
}

/* Hero summary text */
.ai-hero-summary {
  font-size: 1.05rem;
  line-height: 1.78;
  max-width: 680px;
  margin: 0;
  color: var(--text);
}

/* Hero eyebrow: slightly spaced for AI */
.ai-hero-eyebrow {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent-light);
  margin: 0 0 14px;
}

/* Hero h1: editorial weight */
.ai-hero-h1 {
  font-size: clamp(1.75rem, 3.2vw, 2.5rem);
  letter-spacing: -0.025em;
  line-height: 1.12;
  margin: 0 0 16px;
  font-family: Georgia, "Times New Roman", serif;
}

.ai-lobby-card-link {
  display: block;
  height: 100%;
  color: var(--text);
  text-decoration: none;
}

.ai-lobby-card-link:hover {
  text-decoration: none;
}

.ai-atlas-card {
  height: 100%;
}

.ai-atlas-compare-card {
  background: color-mix(in srgb, var(--panel) 88%, white 12%);
}

/* ── AI Atlas browse · V11.2 fingerprint row cards ───────────────────────── */

.ai-atlas-fingerprint-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  border-top: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
  border-left: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
}

.ai-atlas-fingerprint-card {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
  padding: 22px 24px 20px;
  background: var(--panel);
  border-right: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
  border-bottom: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
}

.ai-atlas-fingerprint-card__left {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.ai-atlas-fingerprint-card__num {
  margin: 0;
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  color: var(--muted);
}

.ai-atlas-fingerprint-card__name {
  margin: 0;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.3rem;
  font-weight: 700;
  line-height: 1.18;
  letter-spacing: -0.01em;
  color: var(--text);
  text-wrap: balance;
}

.ai-atlas-fingerprint-card__def {
  margin: 0;
  font-size: 0.92rem;
  line-height: 1.55;
  color: var(--muted);
}

.ai-atlas-fingerprint-card__diffs {
  list-style: none;
  padding: 0;
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.5;
  color: var(--text);
}

.ai-atlas-fingerprint-card__diffs li {
  position: relative;
  padding-left: 16px;
  margin-bottom: 4px;
}

.ai-atlas-fingerprint-card__diffs li::before {
  content: "›";
  position: absolute;
  left: 2px;
  top: 0;
  color: var(--accent);
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-weight: 600;
}

.ai-atlas-fingerprint-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 14px;
  align-items: baseline;
  padding-top: 12px;
  margin-top: auto;
  border-top: 1px solid var(--line);
  font-size: 0.8rem;
  color: var(--text);
}

.ai-atlas-fingerprint-card__nearest {
  display: inline-flex;
  align-items: baseline;
  gap: 6px;
}

.ai-atlas-fingerprint-card__meta-k {
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
}

.ai-atlas-fingerprint-card__meta-v {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 0.92rem;
  font-weight: 600;
  color: var(--text);
}

.ai-atlas-fingerprint-card__cta {
  margin-left: auto;
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.78rem;
  color: var(--text);
  text-decoration: none;
  border-bottom: 1px solid var(--text);
  padding-bottom: 1px;
}

.ai-atlas-fingerprint-card__cta:hover {
  color: var(--accent);
  border-bottom-color: var(--accent);
}

.ai-atlas-fingerprint-card__right {
  min-width: 0;
}

.ai-archetype-fingerprint {
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--panel) 88%, white 12%);
  padding: 10px 12px 8px;
}

.ai-archetype-fingerprint__head {
  display: flex;
  justify-content: space-between;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 8px;
}

.ai-archetype-fingerprint__scale {
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  letter-spacing: 0.06em;
}

.ai-archetype-fingerprint__rows {
  display: grid;
  gap: 6px;
}

.ai-archetype-fingerprint__row {
  grid-template-columns: minmax(70px, 88px) minmax(56px, 1fr) auto;
  gap: 6px;
}

.ai-archetype-fingerprint__row .v10-segmented-level__label {
  font-size: 0.66rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 600;
}

.ai-archetype-fingerprint__row .v10-segmented-level__cell {
  height: 10px;
}

.ai-archetype-fingerprint__row .v10-segmented-level__value {
  font-size: 0.66rem;
  letter-spacing: 0.04em;
}

.ai-atlas-detail-hero-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 28px;
  align-items: start;
}

.ai-atlas-detail-side {
  min-width: 0;
}

.ai-atlas-detail-columns {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}

.ai-atlas-detail-note {
  padding-top: 16px;
  border-top: 1px solid var(--border);
}

.ai-atlas-detail-note .content-list {
  margin: 0;
  color: var(--muted);
  font-size: 0.9rem;
  line-height: 1.62;
}

.ai-atlas-detail-lean {
  margin: 0;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.02rem;
  font-weight: 700;
  line-height: 1.3;
  color: var(--text);
}

.ai-atlas-detail-neighbor-grid,
.ai-atlas-detail-reading-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}

.ai-atlas-detail-neighbor,
.ai-atlas-detail-reading {
  padding: 18px 20px;
  border: 1px solid var(--border-soft);
  background: color-mix(in srgb, var(--panel) 90%, white 10%);
}

.ai-atlas-detail-neighbor h3 {
  margin: 0;
  font-size: 1.12rem;
  line-height: 1.25;
}

.ai-atlas-detail-reading__title {
  margin: 0;
  color: var(--text);
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.02rem;
  font-weight: 700;
  line-height: 1.28;
  text-decoration: none;
}

.ai-atlas-detail-reading__title:hover {
  color: var(--accent);
}

.ai-atlas-detail-reading__meta {
  margin: 0;
  color: var(--muted);
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.74rem;
  letter-spacing: 0.02em;
  line-height: 1.45;
}

@media (min-width: 720px) {
  .ai-atlas-fingerprint-card {
    grid-template-columns: minmax(0, 1fr) 200px;
    gap: 22px;
  }

  .ai-atlas-detail-hero-grid {
    grid-template-columns: minmax(0, 1.45fr) minmax(260px, 0.8fr);
  }

  .ai-atlas-detail-columns,
  .ai-atlas-detail-neighbor-grid,
  .ai-atlas-detail-reading-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (min-width: 1024px) {
  .ai-atlas-fingerprint-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

/* ── AI Field Guide · V11.2 two-column explainer ─────────────────────────── */

.ai-fg-banner {
  display: inline-flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 10px;
  margin: 0;
  padding: 8px 12px;
  border: 1px solid color-mix(in srgb, var(--border) 60%, var(--accent) 40%);
  border-left: 3px solid var(--accent);
  background: color-mix(in srgb, var(--panel) 88%, white 12%);
  font-size: 0.86rem;
  line-height: 1.5;
  color: var(--text);
}

.ai-fg-banner__lbl {
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
}

.ai-fg-banner__body {
  color: var(--text);
}

.ai-fg-anchorbar {
  display: flex;
  flex-wrap: wrap;
  gap: 6px 8px;
  padding: 12px 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  margin: 0 0 18px;
}

.ai-fg-anchorbar__link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 10px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: color-mix(in srgb, var(--panel) 88%, white 12%);
  font-size: 0.74rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--text);
  text-decoration: none;
}

.ai-fg-anchorbar__link:hover {
  border-color: var(--text);
  text-decoration: none;
}

.ai-fg-anchorbar__pill {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  border: 1px solid var(--border);
  background: var(--panel);
  padding: 1px 6px;
  border-radius: 999px;
}

.ai-fg-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 28px;
  align-items: start;
}

.ai-fg-rail {
  display: none;
}

.ai-fg-content {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 44px;
}

.ai-fg-section {
  scroll-margin-top: 24px;
}

.ai-fg-section__head {
  display: grid;
  grid-template-columns: auto 1fr;
  column-gap: 14px;
  row-gap: 6px;
  align-items: baseline;
  border-top: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
  padding-top: 14px;
}

.ai-fg-section__num {
  margin: 0;
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--muted);
}

.ai-fg-section__title {
  margin: 0;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: -0.012em;
  color: var(--text);
  line-height: 1.18;
  text-wrap: balance;
}

.ai-fg-section__deck {
  grid-column: 1 / -1;
  margin: 0;
  font-size: 0.92rem;
  line-height: 1.6;
  color: var(--muted);
  max-width: 720px;
}

.ai-fg-scope-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}

.ai-fg-scope-card {
  padding: 18px 20px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--panel) 90%, white 10%);
}

.ai-fg-scope-card--limits {
  border-left: 3px solid color-mix(in srgb, var(--accent) 58%, var(--border) 42%);
}

.ai-fg-scope-card__kicker,
.ai-fg-perspective__id {
  margin: 0;
  color: var(--muted);
  font-size: 0.64rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.ai-fg-scope-card h3,
.ai-fg-perspective h3 {
  margin: 0;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.02rem;
  font-weight: 700;
  line-height: 1.28;
  color: var(--text);
}

.ai-fg-scope-card p,
.ai-fg-perspective p {
  margin: 0;
  color: var(--muted);
  font-size: 0.9rem;
  line-height: 1.58;
}

.ai-fg-axes {
  list-style: none;
  padding: 0;
  margin: 0;
  border-top: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
}

.ai-fg-axis {
  display: grid;
  grid-template-columns: 36px 1fr;
  column-gap: 12px;
  row-gap: 8px;
  align-items: start;
  padding: 12px 0;
  border-bottom: 1px solid var(--line);
}

.ai-fg-axis__n {
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.74rem;
  letter-spacing: 0.04em;
  color: var(--muted);
}

.ai-fg-axis__body {
  min-width: 0;
}

.ai-fg-axis__nm {
  margin: 0 0 2px;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.02rem;
  font-weight: 700;
  letter-spacing: -0.005em;
  color: var(--text);
}

.ai-fg-axis__desc {
  margin: 0;
  font-size: 0.88rem;
  line-height: 1.5;
  color: var(--muted);
}

.ai-fg-axis__poles {
  grid-column: 2 / -1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.ai-fg-axis__poles-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 2px 8px;
  min-width: 0;
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--muted);
}

.ai-fg-axis__scale {
  height: 4px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--panel-2) 85%, white 15%);
}

.ai-fg-parts {
  border-top: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
}

.ai-fg-parts__row {
  display: grid;
  grid-template-columns: 1fr;
  border-bottom: 1px solid var(--line);
}

.ai-fg-parts__row--head {
  background: color-mix(in srgb, var(--panel-2) 80%, white 20%);
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
}

.ai-fg-parts__row > div {
  padding: 12px 14px;
  border-bottom: 1px dotted var(--line);
}

.ai-fg-parts__row > div:last-child {
  border-bottom: 0;
}

.ai-fg-parts__pair {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.005em;
  color: var(--text);
}

.ai-fg-parts__pair small {
  display: block;
  margin-top: 2px;
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.68rem;
  letter-spacing: 0.04em;
  font-weight: 500;
  color: var(--muted);
}

.ai-fg-parts__col {
  font-size: 0.92rem;
  line-height: 1.55;
  color: var(--text);
}

.ai-fg-parts__kicker {
  display: block;
  margin-bottom: 2px;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
}

.ai-fg-cross {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  border-top: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
  border-left: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
}

.ai-fg-cross__cell {
  padding: 14px 16px;
  border-right: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
  border-bottom: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
  background: var(--panel);
}

.ai-fg-cross__kicker {
  margin: 0;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--t-institutionalist);
}

.ai-fg-cross__title {
  margin: 4px 0 6px;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.04rem;
  font-weight: 700;
  letter-spacing: -0.005em;
  color: var(--text);
}

.ai-fg-cross__body {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.55;
  color: var(--muted);
}

.ai-fg-cross__ai {
  margin: 8px 0 0;
  padding-top: 8px;
  border-top: 1px dashed var(--line);
  font-size: 0.86rem;
  line-height: 1.5;
  color: var(--text);
}

.ai-fg-cross__ai-k {
  font-weight: 700;
  color: var(--accent);
}

.ai-fg-perspective-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}

.ai-fg-perspective {
  padding: 18px 20px;
  border-top: 1px solid color-mix(in srgb, var(--border) 60%, var(--text) 40%);
  background: color-mix(in srgb, var(--panel) 92%, white 8%);
}

.ai-fg-perspective__limit {
  margin: 0;
  padding-top: 10px;
  border-top: 1px dashed var(--line);
  color: var(--muted);
  font-size: 0.86rem;
  line-height: 1.55;
}

.ai-fg-perspective__limit span {
  color: var(--text);
  font-weight: 700;
}

.ai-fg-perspective p.ai-fg-perspective__question {
  color: var(--text);
  font-family: Georgia, "Times New Roman", serif;
  font-style: italic;
}

.ai-fg-start {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
}

.ai-fg-start__cell {
  padding: 16px 18px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--panel) 90%, white 10%);
}

.ai-fg-start__lbl {
  margin: 0 0 4px;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
}

.ai-fg-start__title {
  margin: 0 0 6px;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: -0.005em;
  color: var(--text);
}

.ai-fg-start__body {
  margin: 0 0 10px;
  font-size: 0.9rem;
  line-height: 1.55;
  color: var(--muted);
}

.ai-fg-start__link {
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.8rem;
  color: var(--text);
  text-decoration: none;
  border-bottom: 1px solid var(--text);
  padding-bottom: 1px;
}

.ai-fg-start__link:hover {
  color: var(--accent);
  border-bottom-color: var(--accent);
}

.ai-fg-futures {
  padding: 16px 18px;
  border: 1px dashed color-mix(in srgb, var(--border) 60%, var(--text) 40%);
  background: transparent;
}

.ai-fg-futures__head {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  justify-content: space-between;
  gap: 8px;
  margin-bottom: 8px;
}

.ai-fg-futures__lbl {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
}

.ai-fg-futures__pill {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--panel) 88%, white 12%);
  padding: 2px 8px;
  border-radius: 999px;
}

.ai-fg-futures__intro {
  margin: 0 0 8px;
  font-size: 0.9rem;
  line-height: 1.6;
  color: var(--muted);
}

.ai-fg-futures__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
}

.ai-fg-futures__scen {
  padding: 10px 12px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--panel) 90%, white 10%);
}

.ai-fg-futures__scen-ttl {
  margin: 0 0 2px;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 0.96rem;
  font-weight: 700;
  letter-spacing: -0.005em;
  color: var(--text);
}

.ai-fg-futures__scen-meta {
  margin: 0;
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 0.74rem;
  letter-spacing: 0.02em;
  color: var(--muted);
}

@media (min-width: 720px) {
  .ai-fg-axis {
    grid-template-columns: 36px minmax(0, 1fr) minmax(220px, 280px);
    align-items: center;
  }

  .ai-fg-axis__poles {
    grid-column: 3 / 4;
    text-align: right;
  }

  .ai-fg-parts__row {
    grid-template-columns: minmax(220px, 240px) minmax(0, 1fr) minmax(0, 1fr);
  }

  .ai-fg-parts__row > div {
    border-bottom: 0;
    border-right: 1px dotted var(--line);
  }

  .ai-fg-parts__row > div:last-child {
    border-right: 0;
  }

  .ai-fg-cross,
  .ai-fg-start,
  .ai-fg-futures__grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .ai-fg-scope-grid,
  .ai-fg-perspective-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (min-width: 960px) {
  .ai-fg-anchorbar {
    display: none;
  }

  .ai-fg-layout {
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 36px;
  }

  .ai-fg-rail {
    display: block;
    position: sticky;
    top: 24px;
    padding-right: 20px;
    border-right: 1px solid var(--line);
  }

  .ai-fg-rail__lbl {
    margin: 0 0 10px;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .ai-fg-rail__list {
    list-style: none;
    counter-reset: ai-fg-rail;
    padding: 0;
    margin: 0;
  }

  .ai-fg-rail__item {
    counter-increment: ai-fg-rail;
    position: relative;
    border-bottom: 1px dotted var(--line);
    padding: 8px 0 8px 28px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 0.92rem;
    letter-spacing: -0.005em;
    color: var(--text);
  }

  .ai-fg-rail__item::before {
    content: counter(ai-fg-rail, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 10px;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size: 0.72rem;
    color: var(--muted);
  }

  .ai-fg-rail__item--optional {
    color: var(--muted);
    font-style: italic;
  }

  .ai-fg-rail__link {
    color: inherit;
    text-decoration: none;
  }

  .ai-fg-rail__link:hover {
    color: var(--accent);
  }

  .ai-fg-rail__pill {
    margin-left: 8px;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-style: normal;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--panel) 88%, white 12%);
    padding: 1px 6px;
    border-radius: 999px;
  }

  .ai-fg-rail__legend {
    margin-top: 18px;
    padding: 10px 12px;
    background: color-mix(in srgb, var(--panel) 88%, white 12%);
    border: 1px solid var(--border);
  }

  .ai-fg-rail__legend-k {
    margin: 0 0 4px;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .ai-fg-rail__legend-v {
    margin: 0;
    font-size: 0.86rem;
    line-height: 1.5;
    color: var(--text);
  }
}

@media (max-width: 720px) {
  .ai-result-lead-card,
  .ai-result-card {
    padding: 18px 20px;
  }

  .ai-hero-h1 {
    font-size: 1.75rem;
  }
}

@media (min-width: 721px) and (max-width: 980px) {
  .ai-result-overview,
  .ai-result-critique-grid {
    grid-template-columns: 1fr;
  }

  .ai-result-policy-grid,
  .ai-result-tension-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media print {
  :root {
    --bg: #ffffff;
    --panel: #ffffff;
    --panel-2: #ffffff;
    --text: #111111;
    --muted: #444444;
    --accent: #222222;
    --accent-light: #444444;
    --border: #c9c9c9;
    --shadow: none;
  }

  html,
  body {
    background: #ffffff;
    color: #111111;
  }

  .site-header,
  .print-hidden {
    display: none !important;
  }

  .site-main {
    width: auto;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  .container,
  .wide-container {
    width: auto;
    max-width: none;
    margin: 0;
  }

  .result-article {
    max-width: none;
  }

  .atlas-toc {
    display: none;
  }

  .atlas-layout {
    grid-template-columns: 1fr;
  }

  .page-space,
  .result-hero,
  .result-section {
    padding-left: 0;
    padding-right: 0;
  }

  .result-hero {
    padding-top: 0;
  }

  .result-section {
    break-inside: avoid;
    page-break-inside: avoid;
  }

  .panel,
  .panel-flush,
  .callout,
  .driver-card,
  .explore-card {
    box-shadow: none;
  }

  .progress-bar {
    background: #ffffff;
    border-color: #999999;
  }

  .progress-fill {
    background: #444444;
  }

  .v10-scale-bar,
  .v10-segmented-level,
  .v10-comparison-row,
  .v10-layer-stack {
    --v10-tone: #222222;
  }

  .v10-scale-bar__track,
  .v10-segmented-level__cell,
  .v10-comparison-row__track,
  .v10-layer-stack__item,
  .v10-layer-stack__status {
    background: #ffffff;
    border-color: #999999;
  }

  .v10-scale-bar__fill {
    background: #222222;
    color: #222222;
  }

  .v10-segmented-level__cell--active {
    border-color: #222222;
    background: #222222;
  }

  .v10-comparison-row__axis {
    border-color: #999999;
  }

  a {
    color: inherit;
    text-decoration: none;
  }
}
